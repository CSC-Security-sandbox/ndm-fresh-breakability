{
  "main": "dist/index.js",
  "name": "@NetApp-Cloud-DataMigrate/jobs-lib",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "version": "0.0.1",
  "author": "NetApp-Cloud-DataMigrater",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "run": "tsc && node dist/index.js",
    "files-producer": "nodemon --exec ts-node src/index.ts files-producer ac9e52f9-b8eb-4218-a73c-9457749d9f60",
    "tasks-producer": "nodemon --exec ts-node src/index.ts tasks-producer ac9e52f9-b8eb-4218-a73c-9457749d9f60",
    "group-files-consumer-1": "nodemon --exec ts-node src/index.ts group-files-consumer ac9e52f9-b8eb-4218-a73c-9457749d9f60 files-group-1",
    "group-files-consumer-2": "nodemon --exec ts-node src/index.ts group-files-consumer ac9e52f9-b8eb-4218-a73c-9457749d9f60 files-group-2",
    "files-consumer-1": "nodemon --exec ts-node src/index.ts files-consumer ac9e52f9-b8eb-4218-a73c-9457749d9f60 files-read-1",
    "files-consumer-2": "nodemon --exec ts-node src/index.ts files-consumer ac9e52f9-b8eb-4218-a73c-9457749d9f60 files-read-2",
    "group-tasks-consumer-1": "nodemon --exec ts-node src/index.ts group-tasks-consumer ac9e52f9-b8eb-4218-a73c-9457749d9f60 tasks-group-1",
    "group-tasks-consumer-2": "nodemon --exec ts-node src/index.ts group-tasks-consumer ac9e52f9-b8eb-4218-a73c-9457749d9f60 tasks-group-2",
    "tasks-consumer-1": "nodemon --exec ts-node src/index.ts tasks-consumer ac9e52f9-b8eb-4218-a73c-9457749d9f60 tasks-read-1",
    "tasks-consumer-2": "nodemon --exec ts-node src/index.ts tasks-consumer ac9e52f9-b8eb-4218-a73c-9457749d9f60 tasks-read-2",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:report": "jest --coverage --verbose  --detectOpenHandles",
    "test:coverage": "jest --coverage --coverageDirectory=coverage --coverageReporters=json-summary --coverageReporters=lcov --coverageReporters=text-summary --outputFile=coverage/unit-test-cases-results.json --json",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix"
  },
  "dependencies": {
    "msgpack-lite": "^0.1.26",
    "redis": "^4.7.0",
    "uuid": "^11.0.5",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@babel/helpers": "^7.27.6",
    "@types/jest": "^29.5.14",
    "@types/msgpack-lite": "^0.1.11",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "fast-uri": "3.1.2",
    "flatted": "3.4.2",
    "postcss": "8.5.10"
  },
  "jest-junit": {
    "suiteName": "Unit Tests",
    "outputDirectory": "./test/unit/test-results",
    "outputName": "junit.xml"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "./",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.module.ts",
      "!**/test/**",
      "!**/dist/**",
      "!**/coverage/**",
      "!**.eslintrc.js",
      "!**/main.ts"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/src/$1"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      ".*\\.module\\.ts$",
      "/coverage",
      "/dist",
      "/test/"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      ".*\\.module\\.ts$",
      "/coverage",
      "/dist",
      "/test/",
      "/entities/",
      ".*\\.protocol\\.ts$",
      "src/protocols/protocol/protocol.ts",
      "src/logger/logger.service.ts",
      "src/work-manager/work-manager.service.ts"
    ]
  }
}
