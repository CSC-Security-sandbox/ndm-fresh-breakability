auth:
  updatePassword: false
  securePassword: true
  username: rabbitmq
  existingPasswordSecret: rabbitmq-credentials
  erlangCookie: "rmqcookie"

ingress:
  enabled: true
  hostname: ""
  ingressClassName: "public"
  annotations:
    nginx.ingress.kubernetes.io/rewrite-target: "/$1"
  extraRules:
    - host: ""
      http:
        paths:
          - path: "/rabbitmq/(.*)"
            pathType: Prefix
            backend:
              service:
                name: "rabbitmq"
                port:
                  name: "http-stats"

tls:
  enabled: true
  autoGenerated: true

persistence:
  enabled: true
  storageClass: "local-storage-rabbitmq"
  size: {{ rabbitmq_data_volume_size }}
  selector:
    matchLabels:
      role: rabbitmq-data

persistentVolumeClaimRetentionPolicy:
  enabled: true
  whenScaled: Retain
  whenDeleted: Retain

replicaCount: {{ rabbitmq_replicas }}

volumePermissions:
  enabled: true

extraPlugins: "rabbitmq_auth_backend_ldap rabbitmq_federation rabbitmq_federation_management"

customReadinessProbe:
  initialDelaySeconds: 30
  timeoutSeconds: 20
  periodSeconds: 30
  failureThreshold: 3
  successThreshold: 1
  exec:
    command:
      - sh
      - '-ec'
      - >-
        curl -f --user rabbitmq:$RABBITMQ_PASSWORD 127.0.0.1:15672/api/health/checks/local-alarms

customLivenessProbe:
  initialDelaySeconds: 30
  timeoutSeconds: 20
  periodSeconds: 30
  failureThreshold: 3
  successThreshold: 1
  exec:
    command:
      - sh
      - '-ec'
      - >-
        curl -f --user rabbitmq:$RABBITMQ_PASSWORD 127.0.0.1:15672/api/health/checks/virtual-hosts
