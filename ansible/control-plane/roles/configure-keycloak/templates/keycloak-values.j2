global:
  imagePullSecrets:
    - azure-dev-acr-creds

postgresql:
    enabled: false

externalDatabase:
    host: "postgres-postgresql.postgres.svc.cluster.local"
    port: 5432
    user: dmadmin
    database: datamigrate
    existingSecret: "keycloak-credentials"
    existingSecretPasswordKey: "datamigrate-db-password"

auth:
  adminUser: kc-admin
  existingSecret: "keycloak-credentials"
  passwordSecretKey: "keycloak-admin-password"

command:
  - "/opt/bitnami/scripts/keycloak/entrypoint.sh"

args:
  - 'bash'
  - '-c'
  - |
      #!/bin/bash

      # Run the init_vault.sh logic
      for env_file in /vault/secrets/*.env; do
        if [ -f "$env_file" ]; then
          echo "Sourcing $env_file"
          source "$env_file"
        fi
      done

      # Execute the entrypoint script
      /opt/bitnami/scripts/keycloak/run.sh

podAnnotations:
  vault.hashicorp.com/agent-inject: "true"
  vault.hashicorp.com/role: "keycloak-role"
  vault.hashicorp.com/agent-inject-secret-postgres.env: "secrets/postgres-secrets/postgres-creds"
  vault.hashicorp.com/agent-inject-secret-keycloak.env: "secrets/keycloak-secrets/keycloak-creds"
  vault.hashicorp.com/agent-inject-status: "update"
  vault.hashicorp.com/agent-inject-template-postgres.env: |{% raw %}
    {{`{{- with secret "secrets/postgres-secrets/postgres-creds" -}}
    export DATAMIGRATE_DB_USERNAME="{{ .Data.POSTGRES_DMADMIN_USER }}"
    export DATAMIGRATE_DB_PASSWORD="{{ .Data.POSTGRES_DMADMIN_PASSWORD }}"
    export KEYCLOAK_DATABASE_USER="{{ .Data.POSTGRES_DMADMIN_USER }}"
    export KEYCLOAK_DATABASE_PASSWORD="{{ .Data.POSTGRES_DMADMIN_PASSWORD }}"
    {{- end -}}`}}
  vault.hashicorp.com/agent-inject-template-keycloak.env: |
    {{`{{- with secret "secrets/keycloak-secrets/keycloak-creds" -}}
    export KEYCLOAK_ADMIN="{{ .Data.KEYCLOAK_ADMIN_USER }}"
    export KEYCLOAK_ADMIN_PASSWORD="{{ .Data.KEYCLOAK_ADMIN_PASSWORD }}"
    {{- end -}}`}}
    {% endraw %}
      
serviceAccount:
    create: true
    name: "keycloak-sa"

initContainers:
    - name: keycloak-customizations
      image: {{ acr_registry }}/keycloak-customizations:{{ keycloak_customizations_tag | default(common_tag) | default("latest") }}
      imagePullPolicy: Always
      command:
        - sh
      args:
        - -c
        - |
          echo "Copying custom theme and providers..."
          cp -R /keycloak/custom/themes/* /themes
          cp -R /keycloak/custom/providers/* /providers
          echo "Successfully copied custom theme and providers to /custom"
      volumeMounts:
        - name: themes
          mountPath: /themes
        - name: providers
          mountPath: /providers
        

initdbScripts:
    load_custom_provider_script.sh: |
      #!/bin/bash
      echo "Loading custom providers from /custom/providers..."
      cp -R /custom/providers/* /opt/bitnami/keycloak/providers
      echo "Successfully loaded custom providers"
    
ingress:
  enabled: true
  annotations:
    nginx.ingress.kubernetes.io/use-regex: "true"
    nginx.ingress.kubernetes.io/force-ssl-redirect: "true"
  hostname: ""
  ingressClassName: "public"
  extraRules:
    - host: ""
      http:
        paths:
          - path: "/keycloak/(.*)"
            pathType: Prefix
            backend:
              service:
                name: "keycloak"
                port:
                  name: "http"

extraVolumeMounts: |
    - name: themes
      mountPath: /opt/bitnami/keycloak/themes
    - name: providers
      mountPath: /custom/providers

extraVolumes: |
    - name: themes
      emptyDir: {}
    - name: providers
      emptyDir: {}

httpRelativePath: /keycloak/
tls:
  enabled: true
  autoGenerated: true
proxy: edge
production: true

extraEnvVars:
    - name: MY_HOST_IP
      valueFrom:
        fieldRef:
          fieldPath: status.hostIP
    - name: KEYCLOAK_HOSTNAME_ADMIN
      value: "https://$(MY_HOST_IP)/keycloak/"
    - name: KEYCLOAK_HOSTNAME
      value: "https://$(MY_HOST_IP)/keycloak/"
    - name: DATAMIGRATE_DB_HOST
      value: postgres-postgresql.postgres.svc.cluster.local
    - name: DATAMIGRATE_DB_PORT
      value: '5432'
    - name: DATAMIGRATE_DB_NAME
      value: datamigrate
    - name: DATAMIGRATE_DB_SSL_MODE
      value: disable
    - name: DATAMIGRATE_DB_SCHEMA
      value: 'migrateadmin'
    - name: KEYCLOAK_DATABASE_SCHEMA
      value: 'migrateadmin'
    - name: KEYCLOAK_PROXY_HEADERS
      value: xforwarded