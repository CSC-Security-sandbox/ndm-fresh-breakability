apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: vault-ingress
  namespace: vault
  annotations:
    nginx.ingress.kubernetes.io/use-regex: "true"
    nginx.ingress.kubernetes.io/force-ssl-redirect: "true"
spec:
  ingressClassName: public
  rules:
  - http:
      paths:
      - path: /ui/(.*)
        pathType: Prefix
        backend:
          service:
            name: vault-active
            port:
              number: 8200

      - path: /v1/(.*)
        pathType: Prefix
        backend:
          service:
            name: vault-active
            port:
              number: 8200

