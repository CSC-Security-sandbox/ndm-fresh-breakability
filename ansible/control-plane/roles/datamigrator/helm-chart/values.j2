
# --------------------------------------------------------------------
# Default values
# This is a YAML-formatted file.
# Declare variables to be passed into your templates.

global:
  registry: {{ acr_registry }}
{% if local_cluster is defined %}
  local_cluster: {{ local_cluster }}
{% endif %}
  
admin-service:
  image:
    tag: {{ admin_service_tag | default(common_tag) | default("latest") }}
  liquibase:
    image:
      tag: {{ admin_service_liquibase_tag | default(liquibase_common_tag) | default("latest") }}
{% if local_cluster is not defined %}
  addResourceLimits: true
  memoryRequest: "512Mi"
  cpuRequest: "200m"
  memoryLimit: "768Mi"
  cpuLimit: "500m"
{% endif %}

