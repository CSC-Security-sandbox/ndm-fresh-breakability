apiVersion: v1
kind: ConfigMap
metadata:
    name: redis-config
    namespace: redis
data:
    master.conf: |
        bind 0.0.0.0
        requirepass welcome
        dir /data
        rename-command FLUSHDB ""
        rename-command FLUSHALL ""
        protected-mode yes
    redis.conf: |
        appendonly yes
        save ""
    replica.conf: |
        dir /data
        rename-command FLUSHDB ""
        rename-command FLUSHALL ""
    users.acl:  |