#!/bin/bash

# Configuration
MAX_RETRIES=3
RETRY_DELAY=5
WAIT_TIMEOUT=600

# Function to log messages with timestamps
log_message() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"
}

# Retry function to handle retries
retry() {
    local retries=$1
    local command=$2
    local delay=${3:-$RETRY_DELAY}
    local timeout=${4:-$WAIT_TIMEOUT}
    local attempt=1

    while [ $attempt -le $retries ]; do
        log_message "Attempt $attempt: $command"
        timeout $timeout bash -c "$command"
        if [ $? -eq 0 ]; then
            return 0
        fi
        log_message "Command failed, retrying in $delay seconds..."
        sleep $delay
        attempt=$((attempt + 1))
    done
    log_message "Command failed after $retries attempts: $command"
    return 1
}

# Function to handle failure and exit the script
handle_failure() {
    log_message "[ERROR] $1"
    exit 1
}

# Check if required environment variables are set
log_message "Checking required environment variables..."
if [[ -z "${CONTROL_PLANE_IP}" || -z "${PROJECT_API_KEY}" ]]; then
  handle_failure "One or more required environment variables (CONTROL_PLANE_IP, PROJECT_API_KEY) are missing."
fi
log_message "Required environment variables are set."

# Create and write to /opt/datamigrator/conf/worker.env
log_message "Creating /opt/datamigrator/conf/worker.env with CONTROL_PLANE_IP and SOCKET_SERVER."
{
  echo ""
  echo "FILE_SERVICE_BASEURL=https://${CONTROL_PLANE_IP}/api/v1"
  echo "SOCKET_SERVER=wss://${CONTROL_PLANE_IP}/event"
} >> /opt/datamigrator/conf/worker.env

# Check if the worker.env file was created successfully
if [[ $? -ne 0 ]]; then
  handle_failure "Failed to create /opt/datamigrator/conf/worker.env."
fi
log_message "worker.env file created successfully."

# Create and write to /opt/datamigrator/conf/worker-config.json
log_message "Creating /opt/datamigrator/conf/worker-config.json with PROJECT_API_KEY."
cat <<EOF > /opt/datamigrator/conf/worker-config.json
{
  "api_key": "${PROJECT_API_KEY}"
}
EOF

# Check if the worker-config.json file was created successfully
if [[ $? -ne 0 ]]; then
  handle_failure "Failed to create /opt/datamigrator/conf/worker-config.json."
fi
log_message "worker-config.json file created successfully."

# Start the worker service (Log only setup-related information here)
log_message "Starting the worker service."
retry $MAX_RETRIES "systemctl start datamigrator-worker.service" || handle_failure "Failed to start worker service."

# Ensure the worker service is enabled to start on boot
log_message "Enabling worker service to start on boot."
retry $MAX_RETRIES "systemctl enable datamigrator-worker.service" || handle_failure "Failed to enable worker service to start on boot."

log_message "Worker service setup complete. Service started and enabled successfully."
