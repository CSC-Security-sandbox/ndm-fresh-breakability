{
  "name": "ndm-monorepo",
  "private": true,
  "version": "0.0.1",
  "description": "NDM monorepo – all services and shared libraries",
  "workspaces": [
    "lib/*",
    "services/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:libs": "npm run build --workspace=lib/auth-lib --workspace=lib/logger-lib --workspace=lib/api-handler-lib --workspace=lib/jobs-lib",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "overrides": {
    "fast-uri": "3.1.2",
    "follow-redirects": "1.16.0",
    "flatted": "3.4.2",
    "picomatch": "4.0.4",
    "postcss": "8.5.10",
    "multer": "2.1.1",
    "lodash": "4.18.1",
    "form-data": "^4.0.4",
    "sha.js": "^2.4.12",
    "serialize-javascript": "^7.0.3",
    "protobufjs": "7.5.6",
    "path-to-regexp": "8.4.2",
    "brace-expansion": "5.0.6",
    "minimatch": "^10.2.3",
    "handlebars": "^4.7.9",
    "test-exclude": "^8.0.0",
    "rxjs": "7.8.2",
    "@nestjs/common": "11.1.18",
    "@nestjs/core": "11.1.18"
  }
}
