{
  "name": "ndm-monorepo",
  "private": true,
  "workspaces": [
    "lib/*",
    "services/*"
  ],
  "scripts": {
    "build": "npm run build:libs && npm run build:services",
    "build:libs": "npm run build --workspace=lib/logger-lib --workspace=lib/auth-lib --workspace=lib/jobs-lib --workspace=lib/api-handler-lib",
    "build:services": "npm run build --workspace=services/admin-service --workspace=services/config-service --workspace=services/db-writer --workspace=services/jobs-service --workspace=services/reports-service --workspace=services/support-service --workspace=services/worker",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "overrides": {
    "fast-uri": "3.1.2",
    "follow-redirects": "1.16.0",
    "flatted": "3.4.2",
    "picomatch": "4.0.4",
    "postcss": "8.5.10",
    "multer": "2.1.1",
    "lodash": "4.18.1",
    "lodash-es": "4.18.1",
    "form-data": "^4.0.4",
    "sha.js": "^2.4.12",
    "tar": "^7.5.11",
    "fast-xml-parser": "^5.5.7",
    "glob": "^10.5.0",
    "jws": "^3.2.3",
    "qs": "^6.14.1",
    "js-yaml": "^4.1.1",
    "minimatch": "^10.2.3",
    "serialize-javascript": "^7.0.3",
    "validator": "13.15.22",
    "test-exclude": "^8.0.0",
    "handlebars": "^4.7.9",
    "protobufjs": "7.5.6",
    "path-to-regexp": "8.4.2",
    "brace-expansion": "5.0.6",
    "@isaacs/brace-expansion": "5.0.1",
    "uuid": "11.1.1",
    "rxjs": "7.8.2",
    "file-type": "21.3.4",
    "@nestjs/common": "11.1.18",
    "@nestjs/core": "11.1.18",
    "basic-ftp": "5.3.1",
    "pbkdf2": "3.1.3",
    "react-is": "19.2.3",
    "@swc/core": "1.15.21",
    "diff": "4.0.4",
    "typeorm": {
      "glob": "^10.5.0"
    },
    "@nestjs/cli": {
      "glob": "^10.5.0"
    },
    "react-syntax-highlighter": {
      "refractor": "^5.0.0"
    },
    "refractor": {
      "prismjs": "^1.30.0"
    },
    "hbs": {
      "handlebars": "^4.7.9"
    }
  }
}
