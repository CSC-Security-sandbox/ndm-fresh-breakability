# ONTAP Configuration for Parallel Testing (Volume Cloning)
# Enable this to automatically clone volumes for parallel test execution
# ONTAP Volume Cloning Configuration (Always Enabled)
# Required for parallel test execution with isolated volumes

# Source ONTAP Configuration
ONTAP_SRC_API_URL="https://10.192.7.21"
ONTAP_SYSTEM_MANAGER_SRC_USERNAME="admin"
ONTAP_SYSTEM_MANAGER_SRC_PASSWORD="**************"
ONTAP_SRC_SVM_NAME="svmSourceAutomation"

# Destination ONTAP Configuration
ONTAP_DST_API_URL="https://10.192.7.20"
ONTAP_SYSTEM_MANAGER_DST_USERNAME="admin"
ONTAP_SYSTEM_MANAGER_DST_PASSWORD="**************"
ONTAP_DST_SVM_NAME="svmDestAutomation"

# NFS Volumes - Comma-separated list of master volumes to clone
ONTAP_NFS_SOURCE_VOLUMES="master_nfs_vol_dnd_src_automation_1,master_nfs_vol_dnd_src_automation_2,master_nfs_vol_dnd_src_automation_3"
ONTAP_NFS_DEST_VOLUMES="master_nfs_vol_dnd_dest_automation_1,master_nfs_vol_dnd_dest_automation_2"
# NFS Host IPs (must match volume count)
ONTAP_NFS_SRC_HOST_IP="10.192.7.111,10.192.7.111,10.192.7.111"
ONTAP_NFS_DST_HOST_IP="10.192.7.44,10.192.7.44"

# SMB ONTAP Volumes - Comma-separated list of master volumes to clone (for parallel execution)
# These volumes are on ONTAP and support FlexClone
ONTAP_SMB_SOURCE_VOLUMES="master_smb_vol_dnd_src_automation_1,master_smb_vol_dnd_src_automation_2,master_smb_vol_dnd_src_automation_3,master_smb_vol_dnd_src_automation_4_perms1"
ONTAP_SMB_DEST_VOLUMES="master_smb_vol_dnd_dest_automation_1,master_smb_vol_dnd_dest_automation_2,master_smb_vol_dnd_dest_automation_3_perms2"
# SMB Host IPs (must match volume count)
ONTAP_SMB_SRC_HOST_IP="10.192.7.111,10.192.7.111,10.192.7.111,10.192.7.111"
ONTAP_SMB_DST_HOST_IP="10.192.7.44,10.192.7.44,10.192.7.44"

# SMB AD Server Volumes - Direct access volumes (no cloning support)
# These volumes are on AD Server and cannot be cloned
# Used by specific tests like TC-SMB-REDIRECTS and TC-SMB-RESTRICTED-ACCESS

# Azure AD Server
AZURE_AD_SMB_SOURCE_VOLUMES="SMB-completion,auto_smb_restrictedVol,auto_shorts_name"
AZURE_AD_SMB_SOURCE_HOST_IP="172.30.202.5,172.30.202.5,172.30.202.5"

# GCP AD Server
GCP_AD_SMB_SOURCE_VOLUMES="SMB-completion,auto_smb_restrictedVol"
GCP_AD_SMB_SOURCE_HOST_IP="172.30.205.243,172.30.205.243"