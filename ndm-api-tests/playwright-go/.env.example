# ──────────────────────────────────────────────────────────────
# NDM Playwright-Go Tests — Environment Configuration
# ──────────────────────────────────────────────────────────────
# Copy to .env and fill in values
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────

# ─── Control Plane & Authentication ──────────────────────────
BASE_URL=https://172.30.205.249
NDM_TEST_USER=admin@datamigrator.local
NDM_TEST_PASSWORD=welcome

# ─── Source File Server ──────────────────────────────────────
SOURCE_HOST=10.192.7.105
PROTOCOL=NFS
PROTOCOL_USERNAME=root
PROTOCOL_PASSWORD=

# ─── Source export paths (comma-separated, leave empty to auto-pick first N)
SOURCE_EXPORT_PATHS=

# ─── Destination File Server ────────────────────────────────
DESTINATION_HOST=10.127.176.21
DESTINATION_PROTOCOL_USERNAME=root
DESTINATION_PROTOCOL_PASSWORD=
DESTINATION_EXPORT_PATHS=

# ─── Test Tuning ────────────────────────────────────────────
# Max export paths to discover when SOURCE/DESTINATION_EXPORT_PATHS is empty (default: 5)
MAX_DISCOVERY_PATHS=5

# Minimum workers to associate with each file server (default: 2)
MIN_WORKERS=2

# Seconds in future to schedule migration job (default: 90)
SCHEDULE_DELAY_SEC=90
