# ──────────────────────────────────────────────────────────────
# NDM Playwright-Go Tests — Environment Configuration
# ──────────────────────────────────────────────────────────────
# Copy to .env and fill in values:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────

# ─── Control Plane & Authentication ──────────────────────────
BASE_URL=https://172.30.205.249
NDM_TEST_USER=admin@datamigrator.local
NDM_TEST_PASSWORD=welcome

# ─── Source File Server ──────────────────────────────────────
SOURCE_HOST=10.192.7.105
PROTOCOL=NFS
PROTOCOL_USERNAME=root
PROTOCOL_PASSWORD=

# ─── Source export paths (comma-separated, at least 2 for TC-001)
SOURCE_EXPORT_PATHS=/ifs/exampleexport

# ─── Destination File Server ────────────────────────────────
DESTINATION_HOST=10.127.176.21
DESTINATION_PROTOCOL_USERNAME=root
DESTINATION_PROTOCOL_PASSWORD=
DESTINATION_EXPORT_PATHS=/jv-vol
