NEXT_PUBLIC_PORT={PORT_TO_EXPOSE}
NEXT_PUBLIC_SESSION_KEY={SESSION_KEY}
NEXT_PUBLIC_HARD_CODE_ACCOUNT_ID={ACCOUNT_ID}
NEXT_PUBLIC_API_LIMIT=1000
NEXT_PUBLIC_TIME_INTERVAL=30000 #in milliseconds

# Following URLs will be used for mapping API URL - FROM
NEXT_PUBLIC_ADMIN_SERVICE_URL={URL}
NEXT_PUBLIC_CONFIG_SERVICE_URL={URL}
NEXT_PUBLIC_JOBS_SERVICE_URL={URL}
NEXT_PUBLIC_WORKERS_SERVICE_URL={URL}
NEXT_PUBLIC_WORK_MANGER_URL={URL}
NEXT_PUBLIC_REPORTS_SERVICE_URL={URL}
NEXT_PUBLIC_FILE_SERVICE_URL={URL}

# Following URLs will be used for mapping API URL - TO (ngnix/docker)
NEXT_PUBLIC_ADMIN_SERVICE_ENDPOINT={URL}
NEXT_PUBLIC_CONFIG_SERVICE_ENDPOINT={URL}
NEXT_PUBLIC_JOBS_SERVICE_ENDPOINT={URL}
NEXT_PUBLIC_REPORTS_SERVICE_ENDPOINT={URL}
NEXT_PUBLIC_FILE_SERVICE_ENDPOINT={URL}
NEXT_PUBLIC_WORKERS_SERVICE_ENDPOINT={URL}

# KEYCLOAK
NEXT_PUBLIC_KEYCLOAK_HOST={KEYCLOAK_URL}
NEXT_PUBLIC_KEYCLOAK_REALM=netapp
NEXT_PUBLIC_KEYCLOAK_CLIENT=netapp-cli
NEXT_PUBLIC_KEYCLOAK_AUTHORITY={KEYCLOAK_URL}/realms/netapp
NEXT_PUBLIC_KEYCLOAK_GRANT_TYPE=authorization_code
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=netapp-cli
NEXT_PUBLIC_KEYCLOAK_CLIENT_SECRET={KEYCLOAK_CLIENT_SECRET}
NEXT_PUBLIC_KEYCLOAK_REDIRECT_URI={HOMEPAGE_URL}
NEXT_PUBLIC_KEYCLOAK_RESPONSE_TYPE=code
NEXT_PUBLIC_KEYCLOAK_POST_LOGOUT_REDIRECT_URI={HOMEPAGE_URL}

VITE_APP_TITLE=TITLe
