  <h2>Chain of custody</h2>
  <table style="border:1px solid black;border-collapse: separate;border-spacing: 0;text-align:left;">
   <thead>
    <tr style="background-color:#dbdbdb;">
     <th colspan="2" style="padding: 3px 8px;">Source</th>
     <th colspan="5" style="padding: 3px 8px;">Target</th>
     <th colspan="3" style="padding: 3px 8px;">Entry type</th>
     <th colspan="3" style="padding: 3px 8px;">Entry status</th>
     <th colspan="3" style="padding: 3px 8px;">Chain of Custody</th>
    </tr>
   </thead>
   <thead>
    <tr class="bottom" style="border-bottom:1px solid black;background-color:#dbdbdb;">
     <th style="padding: 3px 8px;">File Server</th>
     <th style="padding: 3px 8px;">Path</th>
     <th style="padding: 3px 8px;">File Server</th>
     <th style="padding: 3px 8px;">Path</th>
     <th style="padding: 3px 8px;">Protocol</th>
     <th style="padding: 3px 8px;">Version</th>
     <th style="padding: 3px 8px;">Type</th>
     <th style="padding: 3px 8px;">Directory</th>
     <th style="padding: 3px 8px;">File</th>
     <th style="padding: 3px 8px;">Other</th>
     <th style="padding: 3px 8px;">In sync</th>
     <th style="padding: 3px 8px;">Out of sync</th>
     <th style="padding: 3px 8px;">Other</th>
     <th style="padding: 3px 8px;">Path</th>
     <th style="padding: 3px 8px;">Size</th>
     <th style="padding: 3px 8px;">Digest</th>
    </tr>
   </thead>
   <tbody>
    <tr class="darker" style="background-color: #f0f0f0;">
      <td style="padding: 3px 8px;">{{summary.source.file_server}}</td>
      <td style="padding: 3px 8px;">{{summary.source.path}}</td>
      <td style="padding: 3px 8px;">{{summary.target.file_server}}</td>
      <td style="padding: 3px 8px;">{{summary.target.path}}</td>
      <td style="padding: 3px 8px;">{{summary.source.protocol}}</td>
      <td style="padding: 3px 8px;">{{summary.source.protocol_version}}</td>
      <td style="padding: 3px 8px;">{{summary.source.job_type}}</td>
     <td style="padding: 3px 8px;">-</td>
     <td style="padding: 3px 8px;">-</td>
     <td style="padding: 3px 8px;">-</td>
     <td style="padding: 3px 8px;">-</td>
     <td style="padding: 3px 8px;">-</td>
     <td style="padding: 3px 8px;">-</td>
     <td style="padding: 3px 8px;">/</td>
     <td style="padding: 3px 8px;"></td>
     <td style="padding: 3px 8px;">-</td>
    </tr>
   </tbody>
  </table>