<h2 style="color: #0067C5; font-family: 'Segoe UI', Arial, sans-serif; margin: 20px 0 10px; padding-bottom: 8px; border-bottom: 2px solid #0067C5;">Chain of Custody</h2>
<div style="overflow-x: auto; margin-bottom: 25px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
  <table style="width: 100%; border-collapse: collapse; font-family: 'Segoe UI', Arial, sans-serif; font-size: 14px; text-align: left;">
    <thead>
      <tr style="background-color: #0067C5; color: white;">
        <th colspan="2" style="padding: 10px; border-right: 1px solid rgba(255,255,255,0.2);">Source</th>
        <th colspan="5" style="padding: 10px; border-right: 1px solid rgba(255,255,255,0.2);">Target</th>
        <th colspan="3" style="padding: 10px;">Chain of Custody</th>
      </tr>
    </thead>
    <thead>
      <tr style="background-color: #f4f9ff; border-bottom: 2px solid #e1e9f5;">
        <th style="padding: 10px; font-weight: 600;">File Server</th>
        <th style="padding: 10px; font-weight: 600;">Path</th>
        <th style="padding: 10px; font-weight: 600;">File Server</th>
        <th style="padding: 10px; font-weight: 600;">Path</th>
        <th style="padding: 10px; font-weight: 600;">Protocol</th>
        <th style="padding: 10px; font-weight: 600;">Version</th>
        <th style="padding: 10px; font-weight: 600;">Type</th>
        <th style="padding: 10px; font-weight: 600;">Path</th>
        <th style="padding: 10px; font-weight: 600;">Size</th>
        <th style="padding: 10px; font-weight: 600;">Digest</th>
      </tr>
    </thead>
    <tbody>
      {{#each coc}}
        <tr style="border-bottom: 1px solid #e1e9f5;">
          <td style="padding: 10px;">{{../summary.source.file_server}}</td>
          <td style="padding: 10px;">{{../summary.source.path}}</td>
          <td style="padding: 10px;">{{../summary.target.file_server}}</td>
          <td style="padding: 10px;">{{../summary.target.path}}</td>
          <td style="padding: 10px;">{{../summary.source.protocol}}</td>
          <td style="padding: 10px;">{{../summary.source.protocol_version}}</td>
          <td style="padding: 10px; font-weight: 500;">{{../summary.source.job_type}}</td>
          <td style="padding: 10px;">{{path}}</td>
          <td style="padding: 10px;">{{size}}</td>
          <td style="padding: 10px;">{{digest}}</td>
        </tr>
      {{/each}}
      {{#unless coc.length}}
        <tr>
          <td colspan="10" style="padding: 15px; text-align: center; color: #777;">No data available</td>
        </tr>
      {{/unless}}
    </tbody>
  </table>
</div>