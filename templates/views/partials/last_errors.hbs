<h2
  style="color: #0067C5; font-family: 'Segoe UI', Arial, sans-serif; margin: 20px 0 10px; padding-bottom: 8px; border-bottom: 2px solid #0067C5;"
>Last Errors</h2>
<div
  style="overflow-x: auto; margin-bottom: 25px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);"
>
  <table
    style="width: 100%; border-collapse: collapse; font-family: 'Segoe UI', Arial, sans-serif; font-size: 14px; text-align: left;"
  >
    <thead>
      <tr style="background-color: #0067C5; color: white;">
        <th
          colspan="2"
          style="padding: 10px; border-right: 1px solid rgba(255,255,255,0.2);"
        >Source</th>
        <th
          colspan="5"
          style="padding: 10px; border-right: 1px solid rgba(255,255,255,0.2);"
        >Destination</th>
        <th colspan="7" style="padding: 10px;">Errors</th>
      </tr>
    </thead>
    <thead>
      <tr style="background-color: #f4f9ff; border-bottom: 2px solid #e1e9f5;">
        <th style="padding: 10px; font-weight: 600;">File Server</th>
        <th style="padding: 10px; font-weight: 600;">Path</th>
        <th style="padding: 10px; font-weight: 600;">File Server</th>
        <th style="padding: 10px; font-weight: 600;">Path</th>
        <th style="padding: 10px; font-weight: 600;">Protocol</th>
        <th style="padding: 10px; font-weight: 600;">Version</th>
        <th style="padding: 10px; font-weight: 600;">Type</th>
        <th style="padding: 10px; font-weight: 600;">Permission Denied</th>
        <th style="padding: 10px; font-weight: 600;">Out of Space</th>
        <th style="padding: 10px; font-weight: 600;">Not Found</th>
        <th style="padding: 10px; font-weight: 600;">In Use</th>
        <th style="padding: 10px; font-weight: 600;">Timed Out</th>
        <th style="padding: 10px; font-weight: 600;">Network Issues</th>
        <th style="padding: 10px; font-weight: 600;">Other</th>
      </tr>
    </thead>
    <tbody>
      {{#if last_errors}}
        <tr style="border-bottom: 1px solid #e1e9f5;">
          <td
            style="padding: 10px;"
          >{{last_errors.summary.source.file_server}}</td>
          <td style="padding: 10px;">{{last_errors.summary.source.path}}</td>
          <td
            style="padding: 10px;"
          >{{last_errors.summary.target.file_server}}</td>
          <td style="padding: 10px;">{{last_errors.summary.target.path}}</td>
          <td
            style="padding: 10px;"
          >{{last_errors.summary.source.protocol}}</td>
          <td
            style="padding: 10px;"
          >{{last_errors.summary.source.protocol_version}}</td>
          <td
            style="padding: 10px; font-weight: 500;"
          >{{last_errors.summary.source.job_type}}</td>
          <td style="padding: 10px;">{{last_errors.permission_denied}}</td>
          <td style="padding: 10px;">{{last_errors.out_of_space}}</td>
          <td style="padding: 10px;">{{last_errors.file_not_found}}</td>
          <td style="padding: 10px;">{{last_errors.in_use}}</td>
          <td style="padding: 10px;">{{last_errors.timed_out}}</td>
          <td style="padding: 10px;">{{last_errors.network_error}}</td>
          <td style="padding: 10px;">{{last_errors.others}}</td>
        </tr>
      {{else}}
        <tr>
          <td
            colspan="14"
            style="padding: 15px; text-align: center; color: #777;"
          >No data available</td>
        </tr>
      {{/if}}
    </tbody>
  </table>
</div>