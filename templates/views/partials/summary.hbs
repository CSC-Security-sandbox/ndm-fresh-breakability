<h2>Summary</h2>
<table style="border:1px solid black;border-collapse: separate;border-spacing: 0;text-align:left;">
  <thead>
    <tr style="background-color:#dbdbdb;">
      <th colspan="4" style="padding: 3px 8px;">Source</th>
      <th colspan="6" style="padding: 3px 8px;">Target</th>
      <th colspan="4" style="padding: 3px 8px;">Last</th>
      <th colspan="3" style="padding: 3px 8px;">COC Report</th>
      <th colspan="1" style="padding: 3px 8px;"></th>
    </tr>
  </thead>
  <thead>
    <tr class="bottom" style="border-bottom:1px solid black;background-color:#dbdbdb;">
      <th style="padding: 3px 8px;">File Server</th>
      <th style="padding: 3px 8px;">Path</th>
      <th style="padding: 3px 8px;">Items</th>
      <th style="padding: 3px 8px;">Capacity</th>
      <th style="padding: 3px 8px;">File Server</th>
      <th style="padding: 3px 8px;">Path</th>
      <th style="padding: 3px 8px;">Capacity (approx)</th>
      <th style="padding: 3px 8px;">Protocol</th>
      <th style="padding: 3px 8px;">Version</th>
      <th style="padding: 3px 8px;">Type</th>
      <th style="padding: 3px 8px;">#</th>
      <th style="padding: 3px 8px;">Start time</th>
      <th style="padding: 3px 8px;">Duration</th>
      <th style="padding: 3px 8px;">Failures</th>
      <th style="padding: 3px 8px;">State</th>
      <th style="padding: 3px 8px;">file path</th>
      <th style="padding: 3px 8px;">size</th>
      <th style="padding: 3px 8px;">digest</th>
    </tr>
  </thead>
  <tbody>
    {{#if summary.length}}
    {{#each summary}}
    <tr>
      <td style="padding: 3px 8px;">{{ source.file_server }}</td>
      <td style="padding: 3px 8px;">{{ source.path }}</td>
      <td style="padding: 3px 8px;">{{ sum details.files details.directories }}</td>
      <td style="padding: 3px 8px;">{{ details.capacity }}</td>
      <td style="padding: 3px 8px;">{{ target.file_server }}</td>
      <td style="padding: 3px 8px;">{{ target.path }}</td>
      <td style="padding: 3px 8px;">{{ target.capacity }}</td>
      <td style="padding: 3px 8px;">{{ source.protocol }}</td>
      <td style="padding: 3px 8px;">{{ source.protocol_version }}</td>
      <td style="padding: 3px 8px;">{{ source.job_type }}</td>
      <td style="padding: 3px 8px;">{{ details.job_run_id }}</td>
      <td style="padding: 3px 8px;">{{ details.created_at }}</td>
      <td style="padding: 3px 8px;">{{ details.duration }} sec </td>
      <td style="padding: 3px 8px;">{{ details.errors }}</td>
      <td style="padding: 3px 8px;">{{ details.status }}</td>
      <td style="padding: 3px 8px;">{{ coc_report.filePath }}</td>
      <td style="padding: 3px 8px;">{{ coc_report.size }}</td>
      <td style="padding: 3px 8px;">{{ coc_report.status }}</td>
    </tr>
    {{/each }}
    {{else}}
    <tr>
      <td colspan="15" style="padding: 3px 8px;">No data available</td>
    </tr>
    {{/if}}
  </tbody>
</table>