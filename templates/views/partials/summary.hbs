<h2>Summary</h2>
<table style="border:1px solid black;border-collapse: separate;border-spacing: 0;text-align:left;">
  <thead>
    <tr style="background-color:#dbdbdb;">
      <th colspan="4" style="padding: 3px 8px;">Source</th>
      <th colspan="6" style="padding: 3px 8px;">Target</th>
      <th colspan="4" style="padding: 3px 8px;">Last</th>
      <th colspan="1" style="padding: 3px 8px;"></th>
    </tr>
  </thead>
  <thead>
    <tr class="bottom" style="border-bottom:1px solid black;background-color:#dbdbdb;">
      <th style="padding: 3px 8px;">File Server</th>
      <th style="padding: 3px 8px;">Path</th>
      <th style="padding: 3px 8px;">Items</th>
      <th style="padding: 3px 8px;">Capacity</th>
      <th style="padding: 3px 8px;">File Server</th>
      <th style="padding: 3px 8px;">Path</th>
      <th style="padding: 3px 8px;">Capacity (approx)</th>
      <th style="padding: 3px 8px;">Protocol</th>
      <th style="padding: 3px 8px;">Version</th>
      <th style="padding: 3px 8px;">Type</th>
      <th style="padding: 3px 8px;">#</th>
      <th style="padding: 3px 8px;">Start time</th>
      <th style="padding: 3px 8px;">Duration</th>
      <th style="padding: 3px 8px;">Failures</th>
      <th style="padding: 3px 8px;">State</th>
    </tr>
  </thead>
  <tbody>
    <tr>
      <td style="padding: 3px 8px;">{{summary.source.file_server}}</td>
      <td style="padding: 3px 8px;">{{summary.source.path}}</td>
      <td style="padding: 3px 8px;">{{summary.source.items}}</td>
      <td style="padding: 3px 8px;">{{summary.source.capacity}}</td>
      <td style="padding: 3px 8px;">{{summary.target.file_server}}</td>
      <td style="padding: 3px 8px;">{{summary.target.path}}</td>
      <td style="padding: 3px 8px;">{{summary.target.capacity}}</td>
      <td style="padding: 3px 8px;">{{summary.source.protocol}}</td>
      <td style="padding: 3px 8px;">{{summary.source.protocol_version}}</td>
      <td style="padding: 3px 8px;">{{summary.source.job_type}}</td>
      <td style="padding: 3px 8px;">{{summary.last_run.id}}</td>
      <td style="padding: 3px 8px;">{{summary.last_run.start_time}}</td>
      <td style="padding: 3px 8px;">{{summary.last_run.duration}}</td>
      <td style="padding: 3px 8px;">{{summary.last_run.failures}}</td>
      <td style="padding: 3px 8px;">{{summary.last_run.state}}</td>
    </tr>
  </tbody>
</table>