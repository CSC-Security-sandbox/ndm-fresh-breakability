  <h2>Iterations</h2>
  <h3>Scan Details</h3>
  <table style="border:1px solid black;border-collapse: separate;border-spacing: 0;text-align:left;">
   <thead>
    <tr style="background-color:#dbdbdb;">
     <th colspan="4" style="padding: 3px 8px;">Summary</th>
     <th colspan="6" style="padding: 3px 8px;">Scan Source</th>
     <th colspan="6" style="padding: 3px 8px;">Scan Target</th>
    </tr>
   </thead>
   <thead>
    <tr class="bottom" style="border-bottom:1px solid black;background-color:#dbdbdb;">
     <th style="padding: 3px 8px;">#</th>
     <th style="padding: 3px 8px;">Protocol</th>
     <th style="padding: 3px 8px;">Status</th>
     <th class="datefmt" style="white-space:nowrap;padding: 3px 8px;">Start time</th>
     <th class="datefmt" style="white-space:nowrap;padding: 3px 8px;">Duration</th>
     <th style="padding: 3px 8px;">Files</th>
     <th style="padding: 3px 8px;">Directories</th>
     <th style="padding: 3px 8px;">Others</th>
     <th style="padding: 3px 8px;">Capacity</th>
     <th style="padding: 3px 8px;">Errors</th>
     <th class="datefmt" style="white-space:nowrap;padding: 3px 8px;">Duration</th>
     <th style="padding: 3px 8px;">Errors</th>
     <th style="padding: 3px 8px;">Files</th>
     <th style="padding: 3px 8px;">Directories</th>
     <th style="padding: 3px 8px;">Others</th>
     <th style="padding: 3px 8px;">Capacity</th>
    </tr>
   </thead>
    {{#if scan_iterations.length}}
    {{#each scan_iterations}}
   <tbody>
    <tr class="darker" style="background-color: #f0f0f0;">
     <th style="padding: 3px 8px;">{{job_run_id}}</th>
     <th style="padding: 3px 8px;">{{job_type}}</th>
     <th style="padding: 3px 8px;">{{status}}</th>
     <td class="datefmt" style="white-space:nowrap;padding: 3px 8px;">{{start_time}}</td>
     <td class="datefmt" style="white-space:nowrap;padding: 3px 8px;">&lt; {{s_duration}}</td>
     <td style="padding: 3px 8px;">{{s_files}}</td>
     <td style="padding: 3px 8px;">{{s_directories}}</td>
     <td style="padding: 3px 8px;">-</td>
     <td style="padding: 3px 8px;">-</td>
     <td class="$iteration.scan_source_errorsColor-odd" style="padding: 3px 8px;">{{s_errors}}</td>
     <td class="datefmt" style="white-space:nowrap;padding: 3px 8px;">&lt;1 min</td>
     <td style="padding: 3px 8px;">27,031</td>
     <td style="padding: 3px 8px;">114</td>
     <td style="padding: 3px 8px;">23</td>
     <td style="padding: 3px 8px;">1.36 GiB</td>
     <td class="$iteration.scan_destination_errorsColor-odd" style="padding: 3px 8px;">-</td>
    </tr>
    {{/each}}
    {{else}}
    <tr>
      <td style="padding: 3px 8px;">-</td>
    </tr>
    {{/if}}
   </tbody>
  </table>