<h2
  style="color: #0067C5; font-family: 'Segoe UI', Arial, sans-serif; margin: 20px 0 10px; padding-bottom: 8px; border-bottom: 2px solid #0067C5;"
>Cutover</h2>
<div
  style="overflow-x: auto; margin-bottom: 25px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);"
>
  <table
    style="width: 100%; border-collapse: collapse; font-family: 'Segoe UI', Arial, sans-serif; font-size: 14px; text-align: left;"
  >
    <thead>
      <tr style="background-color: #0067C5; color: white;">
        <th
          colspan="2"
          style="padding: 10px; border-right: 1px solid rgba(255,255,255,0.2);"
        >Source</th>
        <th
          colspan="5"
          style="padding: 10px; border-right: 1px solid rgba(255,255,255,0.2);"
        >Target</th>
        <th
          colspan="8"
          style="padding: 10px; border-right: 1px solid rgba(255,255,255,0.2);"
        >Cutover</th>
        <th colspan="3" style="padding: 10px;">COC Report</th>
      </tr>
    </thead>
    <thead>
      <tr style="background-color: #f4f9ff; border-bottom: 2px solid #e1e9f5;">
        <th style="padding: 10px; font-weight: 600;">File Server</th>
        <th style="padding: 10px; font-weight: 600;">Path</th>
        <th style="padding: 10px; font-weight: 600;">File Server</th>
        <th style="padding: 10px; font-weight: 600;">Path</th>
        <th style="padding: 10px; font-weight: 600;">Protocol</th>
        <th style="padding: 10px; font-weight: 600;">Version</th>
        <th style="padding: 10px; font-weight: 600;">Type</th>
        <th style="padding: 10px; font-weight: 600;">Time</th>
        <th style="padding: 10px; font-weight: 600;">Duration</th>
        <th style="padding: 10px; font-weight: 600;">Capacity</th>
        <th style="padding: 10px; font-weight: 600;">Files</th>
        <th style="padding: 10px; font-weight: 600;">Directories</th>
        <th style="padding: 10px; font-weight: 600;">Operations</th>
        <th style="padding: 10px; font-weight: 600;">Others</th>
        <th style="padding: 10px; font-weight: 600;">Errors</th>
        <th style="padding: 10px; font-weight: 600;">File Path</th>
        <th style="padding: 10px; font-weight: 600;">Size</th>
        <th style="padding: 10px; font-weight: 600;">Digest</th>
      </tr>
    </thead>
    <tbody>
      {{#if cutovers.length}}
        {{#each cutovers}}
          <tr style="border-bottom: 1px solid #e1e9f5;">
            <td style="padding: 10px;">{{source.file_server}}</td>
            <td style="padding: 10px;">{{source.path}}</td>
            <td style="padding: 10px;">{{target.file_server}}</td>
            <td style="padding: 10px;">{{target.path}}</td>
            <td style="padding: 10px;">{{source.protocol}}</td>
            <td style="padding: 10px;">{{source.protocol_version}}</td>
            <td
              style="padding: 10px; font-weight: 500;"
            >{{source.job_type}}</td>
            <td style="padding: 10px;">{{details.created_at}}</td>
            <td style="padding: 10px;">{{details.duration}} sec</td>
            <td style="padding: 10px;">{{details.capacity}}</td>
            <td style="padding: 10px;">{{details.files}}</td>
            <td style="padding: 10px;">{{details.directories}}</td>
            <td style="padding: 10px;">{{details.operations}}</td>
            <td style="padding: 10px;">-</td>
            <td style="padding: 10px;">{{details.errors}}</td>
            <td style="padding: 10px;">{{coc_report.filePath}}</td>
            <td style="padding: 10px;">{{coc_report.size}}</td>
            <td style="padding: 10px;">{{coc_report.status}}</td>
          </tr>
        {{/each}}
      {{else}}
        <tr>
          <td
            colspan="18"
            style="padding: 15px; text-align: center; color: #777;"
          >No cutover data available</td>
        </tr>
      {{/if}}
    </tbody>
  </table>
</div>