# NDM UI Test Configuration — Example
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env

# ── Setup Mode ────────────────────────────────────────────────────────────────
# Set to "true" to skip project creation and worker registration (local testing
# against an existing CP with a pre-configured demo project).
# Leave unset or "false" for CI/CD pipelines that provision fresh environments.
NDM_SKIP_SETUP=false

# ── Control Plane ─────────────────────────────────────────────────────────────
NDM_BASE_URL=https://<CP_IP>

# ── App Admin credentials ─────────────────────────────────────────────────────
NDM_USERNAME=admin@datamigrator.local
NDM_PASSWORD=<your-password>

# ── Browser settings ──────────────────────────────────────────────────────────
# NDM_CHROME_PATH: use your system Chrome instead of Playwright's bundled one.
# Required when the CP is only reachable via VPN/proxy (bundled Chromium ignores
# macOS proxy settings). Leave empty to use the bundled Chromium.
NDM_CHROME_PATH=
NDM_HEADLESS=true
NDM_SLOWMO=0
NDM_TIMEOUT=30000

# ── Artifacts ────────────────────────────────────────────────────────────────
NDM_VIDEO_DIR=test-results/videos
NDM_SCREENSHOT_DIR=test-results/screenshots

# ── NFS Source File Server ───────────────────────────────────────────────────
NDM_NFS_SOURCE_FILE_SERVER_NAME_PREFIX=NFS_Source
NDM_NFS_SOURCE_HOST=
NDM_NFS_PROTOCOL_USERNAME=root
NDM_NFS_PROTOCOL_PASSWORD=
NDM_NFS_SOURCE_EXPORT_PATH=

# ── NFS Destination File Server ──────────────────────────────────────────────
NDM_NFS_DESTINATION_FILE_SERVER_NAME_PREFIX=NFS_Destination
NDM_NFS_DESTINATION_HOST=
NDM_NFS_DESTINATION_PROTOCOL_USERNAME=root
NDM_NFS_DESTINATION_PROTOCOL_PASSWORD=
NDM_NFS_DESTINATION_EXPORT_PATH=

# ── Migration timeout ────────────────────────────────────────────────────────
# Max time (ms) to wait for a migration job to complete (default 600000 = 10 min).
NDM_MIGRATION_TIMEOUT_MS=600000

# ── File Server Creation (legacy — prefer NDM_NFS_SOURCE_* above) ───────────
# If NDM_FILE_SERVER_ID is empty, the test creates a new file server using
# these values. If NDM_FILE_SERVER_ID is set, creation is skipped.
NDM_SOURCE_HOST=
NDM_PROTOCOL_USERNAME=root
NDM_PROTOCOL_PASSWORD=
NDM_MIN_WORKERS=1
NDM_FILE_SERVER_NAME_NEW=auto-test-fs

# ── Discovery Tests ──────────────────────────────────────────────────────────
# Primary file server. UUID from the URL: /file-server/<UUID>
# Leave empty to auto-create via NDM_NFS_SOURCE_HOST above.
NDM_FILE_SERVER_ID=
NDM_FILE_SERVER_NAME=

# NFS export path to select in the Bulk Discover table (partial match OK).
NDM_NFS_EXPORT_PATH=

# ── SMB File Server Creation (for test 5.2) ──────────────────────────────
# All three are required to create an SMB file server; test skips if empty.
NDM_SMB_HOST=
NDM_SMB_USERNAME=
NDM_SMB_PASSWORD=
NDM_SMB_SHARE=

# Optional — set to enable Destination test. Auto-skips if empty.
NDM_DESTINATION_FILE_SERVER_ID=

# ── Isilon File Server Creation (for test 5.18) ──────────────────────────
# All three are required to create an Isilon file server; test skips if empty.
NDM_ISILON_HOST=
NDM_ISILON_MGMT_USERNAME=root
NDM_ISILON_MGMT_PASSWORD=
NDM_ISILON_NFS_IP=
NDM_ISILON_NFS_USERNAME=root

# Legacy — set this to use an existing Isilon FS instead of creating fresh.
NDM_ISILON_FILE_SERVER_ID=

# Max time (ms) to wait for a discovery job to complete (default 600000 = 10 min).
NDM_DISCOVERY_TIMEOUT_MS=600000

# ── Migration Tests ──────────────────────────────────────────────────────────
# NFS source file server for migration
NDM_NFS_SOURCE_HOST=
NDM_NFS_SOURCE_EXPORT_PATH=
NDM_NFS_SOURCE_FILE_SERVER_NAME_PREFIX=nfs-src
NDM_NFS_PROTOCOL_USERNAME=root
NDM_NFS_PROTOCOL_PASSWORD=

# NFS destination file server for migration
NDM_NFS_DESTINATION_HOST=172.30.202.22
NDM_NFS_DESTINATION_EXPORT_PATH=/jv-vol-1
# Comma-separated per-test destination export paths (M-001, M-002, M-003)
NDM_NFS_DESTINATION_EXPORT_PATHS=/jv-vol-1,/jv-vol-2,/jv-vol-3
NDM_NFS_DESTINATION_FILE_SERVER_NAME_PREFIX=nfs-dst
NDM_NFS_DESTINATION_PROTOCOL_USERNAME=root
NDM_NFS_DESTINATION_PROTOCOL_PASSWORD=

# SMB source file server for migration
NDM_SMB_MIG_SOURCE_HOST=
NDM_SMB_MIG_SOURCE_AD_SERVER_IP=
NDM_SMB_MIG_SOURCE_USERNAME=
NDM_SMB_MIG_SOURCE_PASSWORD=
NDM_SMB_MIG_SOURCE_SHARE=
NDM_SMB_MIG_SOURCE_FILE_SERVER_NAME_PREFIX=smb-mig-src

# SMB destination file server for migration
NDM_SMB_MIG_DEST_HOST=
NDM_SMB_MIG_DEST_AD_SERVER_IP=
NDM_SMB_MIG_DEST_USERNAME=
NDM_SMB_MIG_DEST_PASSWORD=
NDM_SMB_MIG_DEST_SHARE=
NDM_SMB_MIG_DEST_FILE_SERVER_NAME_PREFIX=smb-mig-dst

# Max time (ms) to wait for a migration job to complete (default 600000 = 10 min).
NDM_MIGRATION_TIMEOUT_MS=600000
