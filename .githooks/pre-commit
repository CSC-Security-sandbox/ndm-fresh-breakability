#!/bin/sh
STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep "^services/jobs-service/.*\.ts$")
if [ -n "$STAGED" ]; then
  echo "Running lint for jobs-service staged files..."
  cd services/jobs-service && npm run lint:changed
  if [ $? -ne 0 ]; then
    echo "Lint failed. Fix errors before committing."
    exit 1
  fi
fi
