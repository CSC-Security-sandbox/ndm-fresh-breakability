<service>
    <id>DatamigratorWorker</id>
    <name>Datamigrator Worker</name>
    <description>Datamigrator Worker Service</description>
    <executable>%BASE%\bin\worker.exe</executable>
    <workingdirectory>%BASE%\bin</workingdirectory>
    <logpath>%BASE%\logs</logpath>
    <log mode="roll-by-size">
        <sizeThreshold>204800</sizeThreshold> 
        <keepFiles>8</keepFiles>
    </log>
    <startmode>Automatic</startmode>
    <delayedAutoStart>true</delayedAutoStart>
    <onfailure action="restart" delay="10 sec"/>
    <resetfailure>1 hour</resetfailure>
    <priority>Normal</priority>
</service>