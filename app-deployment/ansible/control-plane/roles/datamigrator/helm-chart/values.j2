global:
  registry: {{ acr_registry }}
  build_version: {{ build_version }}
{% if local_cluster is defined %}
  local_cluster: {{ local_cluster }}
{% endif %}
  
admin-service:
  image:
    tag: {{ admin_service_tag | default(common_tag) | default("latest") }}
  annotations:
    vault.hashicorp.com/agent-json-patch: '[{"op": "replace", "path": "/imagePullPolicy", "value": "{% if local_cluster is defined %}IfNotPresent{% else %}Never{% endif %}"}]'

