apiVersion: v1
kind: ConfigMap
metadata:
  name: ndm-postgres-cronjob-script
  namespace: datamigrator
data:
  run_ndm_pg_cron.sh: |
    #!/bin/bash
    set -euo pipefail

    echo "Sourcing environment variables from Vault..."
    if [ -f /vault/secrets/postgres.env ]; then 
      source /vault/secrets/postgres.env
    else
      echo "No env file from vault present. Exiting."
      exit 1
    fi

    refresh_mv() {
      local mv_name="$1"
      echo "Refreshing materialized view ${mv_name} concurrently..."
      local start_time=$(date +%s)
      psql -v ON_ERROR_STOP=1 -h "$PGHOST" -U "$PGUSER" -d "$PGDATABASE" \
        -c "REFRESH MATERIALIZED VIEW CONCURRENTLY datamigrator.${mv_name};"
      local end_time=$(date +%s)
      local elapsed=$((end_time - start_time))
      echo "Refreshing materialized view ${mv_name} completed successfully in ${elapsed} seconds."
      echo "------------------------------------------------------------"
    }

    refresh_mv "job_stats_summary_mv"
    refresh_mv "storage_jobs_overview_mv"