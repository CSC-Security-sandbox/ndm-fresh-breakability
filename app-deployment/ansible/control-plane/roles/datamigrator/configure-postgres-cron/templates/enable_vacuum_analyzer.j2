#!/bin/bash

set -euo pipefail

# Configuration
NAMESPACE="datamigrator"
CONFIGMAP_NAME="ndm-postgres-cronjob-cm"

# Cron job configurations
declare -A CRONJOBS
CRONJOBS[1]="ndm-postgres-vacuum-analyze-cronjob"
CRONJOBS[2]="ndm-postgres-mv-cronjob"

declare -A CONFIG_KEYS
CONFIG_KEYS[1]="VACUUM_ANALYZE_ENABLED"
CONFIG_KEYS[2]="MATERIALIZED_VIEW_ENABLED"

declare -A CRON_NAMES
CRON_NAMES[1]="Vacuum Analyze"
CRON_NAMES[2]="Materialized View"

# Global variables set after selection
CRONJOB_NAME=""
CONFIG_KEY=""
CRON_DISPLAY_NAME=""

# -------------------------------------------------------------------
# Logging helpers
# -------------------------------------------------------------------
print_info()    { echo "[INFO] $*"; }
print_success() { echo "[SUCCESS] $*"; }
print_warning() { echo "[WARNING] $*"; }
print_error()   { echo "[ERROR] $*"; }

# -------------------------------------------------------------------
# Cron job selection
# -------------------------------------------------------------------
select_cronjob() {
    echo ""
    echo "Which cron job do you want to perform operations on?"
    echo "1. Vacuum Analyze cron"
    echo "2. Materialized View cron"
    echo "3. Abort execution"
    echo ""
    
    local choice
    while true; do
        read -r -p "Enter your choice (1, 2, or 3): " choice
        case "$choice" in
            1|2)
                CRONJOB_NAME="${CRONJOBS[$choice]}"
                CONFIG_KEY="${CONFIG_KEYS[$choice]}"
                CRON_DISPLAY_NAME="${CRON_NAMES[$choice]}"
                print_info "Selected: ${CRON_DISPLAY_NAME} cron job"
                return 0
                ;;
            3)
                print_info "Exiting script as requested."
                exit 0
                ;;
            *)
                echo "Please enter 1, 2, or 3."
                ;;
        esac
    done
}

# -------------------------------------------------------------------
# Validate cron expression
# -------------------------------------------------------------------
validate_cron_expression() {
    local cron_expr="$1"

    # Must have exactly 5 fields
    local field_count
    field_count=$(awk '{print NF}' <<< "$cron_expr")
    if [ "$field_count" -ne 5 ]; then
        echo "Invalid cron expression: expected 5 fields (minute hour day month weekday)" >&2
        return 1
    fi

    # Basic regex check
    if ! [[ "$cron_expr" =~ ^[0-9\*/,\-]+[[:space:]]+[0-9\*/,\-]+[[:space:]]+[0-9\*/,\-]+[[:space:]]+[0-9\*/,\-]+[[:space:]]+[0-9\*/,\-]+$ ]]; then
        echo "Invalid cron expression format" >&2
        return 1
    fi

    echo "Cron expression validated successfully" >&2
    return 0
}

# -------------------------------------------------------------------
# Ask user for y/n
# -------------------------------------------------------------------
get_user_confirmation() {
    local prompt="$1"
    local response

    while true; do
        read -r -p "$prompt (y/n): " response
        case "$response" in
            y|Y|yes|YES) return 0 ;;
            n|N|no|NO)   return 1 ;;
            *) echo "Please answer yes (y) or no (n)." ;;
        esac
    done
}

# -------------------------------------------------------------------
# Prompt for cron expression
# -------------------------------------------------------------------
get_cron_expression() {
    local cron_expr
    while true; do
        read -r -p "Your cron expression: " cron_expr

        echo "DEBUG: you entered '$cron_expr'" >&2

        if validate_cron_expression "$cron_expr"; then
            echo "$cron_expr"
            return 0
        fi

        if ! get_user_confirmation "Would you like to try again?"; then
            return 1
        fi
    done
}

# -------------------------------------------------------------------
# K8s helpers
# -------------------------------------------------------------------
check_resources() {
    if ! kubectl get configmap "$CONFIGMAP_NAME" -n "$NAMESPACE" &>/dev/null; then
        print_error "ConfigMap '$CONFIGMAP_NAME' does not exist in namespace '$NAMESPACE'"
        exit 1
    fi

    if ! kubectl get cronjob "$CRONJOB_NAME" -n "$NAMESPACE" &>/dev/null; then
        print_error "CronJob '$CRONJOB_NAME' does not exist in namespace '$NAMESPACE'"
        exit 1
    fi

    print_success "Required resources exist"
}

get_config_value() {
    local value
    value=$(kubectl get configmap "$CONFIGMAP_NAME" -n "$NAMESPACE" -o jsonpath="{.data.$CONFIG_KEY}" 2>/dev/null || echo "")
    if [ -z "$value" ]; then
        print_error "Could not retrieve $CONFIG_KEY from ConfigMap"
        exit 1
    fi
    echo "$value"
}

update_config_value() {
    local new_value="$1"
    print_info "Updating ConfigMap with $CONFIG_KEY=$new_value..."
    if kubectl patch configmap "$CONFIGMAP_NAME" -n "$NAMESPACE" --patch "{\"data\":{\"$CONFIG_KEY\":\"$new_value\"}}" &>/dev/null; then
        print_success "ConfigMap updated successfully"
    else
        print_error "Failed to update ConfigMap"
        exit 1
    fi
}

get_current_schedule() {
    local schedule
    schedule=$(kubectl get cronjob "$CRONJOB_NAME" -n "$NAMESPACE" -o jsonpath="{.spec.schedule}" 2>/dev/null || echo "")
    if [ -z "$schedule" ]; then
        print_error "Could not retrieve current cron schedule"
        exit 1
    fi
    echo "$schedule"
}

update_cron_schedule() {
    local new_schedule="$1"
    print_info "Updating CronJob schedule to '$new_schedule'..."
    if kubectl patch cronjob "$CRONJOB_NAME" -n "$NAMESPACE" --patch "{\"spec\":{\"schedule\":\"$new_schedule\"}}" &>/dev/null; then
        print_success "CronJob schedule updated successfully"
    else
        print_error "Failed to update CronJob schedule"
        exit 1
    fi
}

unsuspend_cronjob() {
    print_info "Ensuring CronJob is active..."
    if kubectl patch cronjob "$CRONJOB_NAME" -n "$NAMESPACE" --patch '{"spec":{"suspend":false}}' &>/dev/null; then
        print_success "CronJob is now active"
    else
        print_error "Failed to activate CronJob"
        exit 1
    fi
}

suspend_cronjob() {
    print_info "Suspending CronJob..."
    if kubectl patch cronjob "$CRONJOB_NAME" -n "$NAMESPACE" --type=merge --patch '{"spec":{"suspend":true}}' &> /dev/null; then
        print_success "CronJob suspended successfully"
    else
        print_error "Failed to suspend CronJob"
        exit 1
    fi
}

# -------------------------------------------------------------------
# Main
# -------------------------------------------------------------------
main() {
    print_info "Starting Postgres CronJob Management Script"
    print_info "=================================="

    # Step 0: Select which cron job to manage
    select_cronjob

    # Step 1: Checks
    check_resources

    # Step 2: Gather current state
    print_info "Checking current configuration for ${CRON_DISPLAY_NAME}..."
    current_config=$(get_config_value)
    current_schedule=$(get_current_schedule)
    
    print_info "Current $CONFIG_KEY value: $current_config"
    print_info "Current cron schedule: $current_schedule"

    # Step 3: Collect user decisions (no changes applied yet)
    local new_config="$current_config"
    local new_schedule="$current_schedule"
    local changes_needed=false
    local desired_suspend=false

    # 3a: Enable/disable decision
    if [ "$current_config" = "FALSE" ]; then
        print_warning "${CRON_DISPLAY_NAME} is currently disabled"
        if get_user_confirmation "Do you wish to enable ${CRON_DISPLAY_NAME}?"; then
            new_config="TRUE"
            desired_suspend=false
            changes_needed=true
        else
            print_info "${CRON_DISPLAY_NAME} remains disabled. Exiting."
            exit 0
        fi
    else
        print_info "${CRON_DISPLAY_NAME} is currently enabled"
        if get_user_confirmation "Do you wish to disable ${CRON_DISPLAY_NAME}?"; then
            new_config="FALSE"
            desired_suspend=true
            changes_needed=true
            # When disabling we skip schedule modification prompt
        else
            print_info "${CRON_DISPLAY_NAME} will remain enabled"
        fi
    fi

    # 3b: Only ask for schedule change if remaining enabled
    if [ "$desired_suspend" = false ]; then
        if get_user_confirmation "Do you wish to change the cron expression?"; then
            echo ""
            echo "Enter the new cron expression (minute hour day month weekday)."
            echo "Examples:"
            echo "   0 2 * * *    -> Daily at 2:00 AM"
            echo "   0 */6 * * *  -> Every 6 hours"
            echo "   0 0 * * 0    -> Weekly on Sunday at midnight"
            echo ""
            new_schedule=$(get_cron_expression)
            if [ -z "$new_schedule" ]; then
                print_error "Failed to get valid cron expression. Exiting without making any changes."
                exit 1
            fi
            print_success "Cron expression validated successfully"
            # Only mark changes if schedule differs
            if [ "$new_schedule" != "$current_schedule" ]; then
                changes_needed=true
            fi
        else
            print_info "Keeping current cron schedule: $current_schedule"
        fi
    fi

    # Step 4: Apply changes
    if [ "$changes_needed" = true ]; then
        print_info "Applying changes..."

        if [ "$new_config" != "$current_config" ]; then
            update_config_value "$new_config"
        fi

        if [ "$new_schedule" != "$current_schedule" ]; then
            update_cron_schedule "$new_schedule"
        fi

        if [ "$desired_suspend" = true ]; then
            suspend_cronjob
            print_success "${CRON_DISPLAY_NAME} disabled and suspended."
        else
            unsuspend_cronjob
            print_success "${CRON_DISPLAY_NAME} enabled and active."
        fi

        print_info "Final schedule: $(get_current_schedule)"
    else
        print_success "No changes were made. CronJob '$CRONJOB_NAME' remains as-is with schedule: $current_schedule"
    fi
}

main "$@"
