        "h": 1,
        "w": 24,
        "x": 0,
        "y": 42
      },
      "id": 105,
      "title": "\ud83d\udd37 Task Queue Wait Time",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$DataSource"
      },
      "description": "Time a task waits in the queue before a thread picks it up, broken down by file size band (1kb, 1mb, 10mb, 100mb, 1gb). High wait times indicate thread pool saturation for that band.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "s",
          "decimals": 4,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "pointSize": 5,
            "spanNulls": true,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 43
      },
      "id": 6,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$DataSource"
          },
          "expr": "max by (band_name) (worker_task_queue_wait_seconds{workflow_id=~\"$workflow_id\", worker_id=~\"$worker\"})",
          "legendFormat": "{{band_name}}",
          "refId": "wait"
        }
      ],
      "title": "Task Queue Wait \u2014 by file size band",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 51
      },
      "id": 107,
      "title": "\ud83d\udd37 Worker Threads",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$DataSource"
      },
      "description": "Live thread pool status: total threads, available (idle), and busy (processing tasks). When available drops to 0 the thread pool is saturated.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "pointSize": 5,
            "spanNulls": true,
            "axisCenteredZero": false,
            "showPoints": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Total"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#8AB8FF",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Available"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#73BF69",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Busy"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#FF9830",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 52
      },
      "id": 10,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$DataSource"
          },
          "expr": "sum(worker_threads_status{worker_id=~\"$worker\", status=\"total\"})",
          "legendFormat": "Total",
          "refId": "total"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$DataSource"
          },
          "expr": "sum(worker_threads_status{worker_id=~\"$worker\", status=\"available\"})",
          "legendFormat": "Available",
          "refId": "available"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$DataSource"
          },
          "expr": "sum(worker_threads_status{worker_id=~\"$worker\", status=\"busy\"})",
          "legendFormat": "Busy",
          "refId": "busy"
        }
      ],
      "title": "Thread Pool Status \u2014 total / available / busy",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$DataSource"
      },
      "description": "Number of tasks queued per file-size band (1kb, 1mb, 10mb, 100mb, 1gb). Spikes indicate backpressure in that band.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "pointSize": 5,
            "spanNulls": true,
            "axisCenteredZero": false,
            "showPoints": "auto",
            "stacking": {
              "mode": "normal",
              "group": "A"
