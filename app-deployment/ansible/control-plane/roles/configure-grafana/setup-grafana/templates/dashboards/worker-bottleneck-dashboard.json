{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$DataSource"
      },
      "description": "Select a workflow (job run) and set the time range to the workflow run. Duration panels show **total cumulative processing time** summed across all files and threads. Requires ADDITIONAL_METRICS=true.",
      "gridPos": {
        "h": 2,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 0,
      "options": {
        "content": "**Workflow (job run id):** $workflow_id  \n**Time range:** $__from \u2013 $__to (set to the workflow run period).  \nDuration panels show total cumulative processing time summed across all files and threads.  \nIf the dropdown is empty or only \"unknown\", set ADDITIONAL_METRICS=true on the worker and ensure workflows pass jobRunId to activities.",
        "mode": "markdown"
      },
      "title": "",
      "type": "text"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 2
      },
      "id": 100,
      "title": "\ud83d\udd37 Top-level Operation Durations",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$DataSource"
      },
      "description": "Total number of files successfully migrated (copy + checksum completed) for the selected workflow.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#3274D9",
                "value": null
              }
            ]
          },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 3
      },
      "id": 17,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$DataSource"
          },
          "expr": "sum(max by (worker_id) (worker_files_migrated_total{workflow_id=~\"$workflow_id\", worker_id=~\"$worker\"}))",
          "instant": true,
          "legendFormat": "Files Migrated",
          "refId": "files"
        }
      ],
      "title": "Files Migrated",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$DataSource"
      },
      "description": "Total cumulative processing time for each top-level operation, summed across all files and threads. file_copy includes queue wait + file streaming + source & target checksum.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "s",
          "decimals": 4
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Total (s)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#3274D9",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 7
      },
      "id": 1,
      "options": {
        "orientation": "vertical",
        "barWidth": 0.5,
        "showValue": "always",
        "groupWidth": 0.7,
        "stacking": "none",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "xTickLabelRotation": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$DataSource"
          },
          "expr": "max by (operation) (worker_additional_operation_duration_seconds_sum{workflow_id=~\"$workflow_id\", worker_id=~\"$worker\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "total"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "Value": "Total (s)",
              "operation": "Operation"
            }
          }
        }
      ],
      "title": "Total operation time (file_copy+checksum, stamp_meta, copy_dir) \u2014 seconds",
      "type": "barchart"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$DataSource"
      },
      "description": "Percentage of total operation time spent in each operation (file_copy+checksum, stamp_meta, copy_dir). Shows where the migration spends its processing time proportionally.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "percent",
          "decimals": 1
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 7
      },
      "id": 15,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "pieType": "donut",
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "percent",
            "value"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$DataSource"
          },
          "expr": "max by (operation) (worker_additional_operation_duration_seconds_sum{workflow_id=~\"$workflow_id\", worker_id=~\"$worker\"}) / ignoring(operation) group_left sum(max by (operation) (worker_additional_operation_duration_seconds_sum{workflow_id=~\"$workflow_id\", worker_id=~\"$worker\"})) * 100",
          "format": "time_series",
          "instant": true,
          "legendFormat": "{{operation}}",
          "refId": "pct"
        }
      ],
      "title": "Operation time \u2014 % breakdown",
      "type": "piechart"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 15
      },
      "id": 101,
      "title": "\ud83d\udd37 Stamp Phase Breakdown",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$DataSource"
      },
      "description": "Total cumulative time spent in each stamp phase (excl. ACL), summed across all files.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "s",
          "decimals": 4
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Total (s)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#3274D9",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "id": 2,
      "options": {
        "orientation": "vertical",
        "barWidth": 0.5,
        "showValue": "always",
        "groupWidth": 0.7,
        "stacking": "none",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "xTickLabelRotation": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$DataSource"
          },
          "expr": "max by (phase) (worker_stamp_phase_duration_seconds_sum{phase!~\"acl_.*\", workflow_id=~\"$workflow_id\", worker_id=~\"$worker\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "total"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "Value": "Total (s)",
              "phase": "Phase"
            }
          }
        }
      ],
      "title": "Total stamp phase time (s) \u2014 by phase",
      "type": "barchart"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 24
