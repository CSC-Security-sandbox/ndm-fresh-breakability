    {
      "datasource": {
        "type": "prometheus",
        "uid": "$DataSource"
      },
      "description": "Active tasks currently being processed by worker threads, and total thread errors (worker_error, worker_exit, task_timeout) over the selected time range.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "pointSize": 5,
            "spanNulls": true,
            "axisCenteredZero": false,
            "showPoints": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Active Tasks"
            },
