          "expr": "max by (phase) (worker_copy_phase_duration_seconds_sum{workflow_id=~\"$workflow_id\", worker_id=~\"$worker\"}) / ignoring(phase) group_left sum(max by (phase) (worker_copy_phase_duration_seconds_sum{workflow_id=~\"$workflow_id\", worker_id=~\"$worker\"})) * 100",
          "format": "time_series",
