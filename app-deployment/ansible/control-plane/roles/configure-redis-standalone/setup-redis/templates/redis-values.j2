#reference: https://artifacthub.io/packages/helm/bitnami/redis?modal=values
global:
  security:
    allowInsecureImages: true

architecture: standalone
auth:
  enabled: true
  password: "welcome"

existingConfigmap: "redis-config"

image:
  registry: docker.io
  repository: bitnami/redis
  tag: 8.2.1-debian-12-r0
  pullPolicy: "{% if local_cluster is defined %}IfNotPresent{% else %}Never{% endif %}"

master:
  count: 1
  persistence:
    enabled: true
    storageClass: "local-storage-redis"
    size: {{ redis_data_volume_size }}
    selector:
        matchLabels:
            role: redis-data
{% if local_cluster is defined %}
  resources:
    requests:
      cpu: "0.3"
      memory: "512Mi"
    limits:
      cpu: "1"
      memory: "1Gi"
{% else %}
  resources:
    requests:
      cpu: "750m"
      memory: "3Gi"
    limits:
      cpu: "2500m"
      memory: "7Gi"
{% endif %}
  podSecurityContext:
    enabled: true
    fsGroup: {{ vm_gid }}

  containerSecurityContext:
    enabled: true
    runAsUser: {{ vm_uid }}
    runAsGroup: {{ vm_gid }}
    runAsNonRoot: true
    allowPrivilegeEscalation: false
    seccompProfile:
      type: RuntimeDefault
    capabilities:
      drop: ["ALL"] 

volumePermissions:
  enabled: true
  image:
    registry: docker.io
    repository: bitnami/os-shell
    tag: 12-debian-12-r50
    pullPolicy: "{% if local_cluster is defined %}IfNotPresent{% else %}Never{% endif %}"

replica:
  replicaCount: 0

metrics:
  enabled: true
  containerSecurityContext:
    enabled: true
    runAsUser: {{ vm_uid }}
    runAsGroup: {{ vm_gid }}
    runAsNonRoot: true
    allowPrivilegeEscalation: false
    seccompProfile:
      type: RuntimeDefault
    capabilities:
      drop: ["ALL"]
  image:
    registry: docker.io
    repository: bitnami/redis-exporter
    tag: 1.75.0-debian-12-r1
    pullPolicy: "{% if local_cluster is defined %}IfNotPresent{% else %}Never{% endif %}"

kubectl:
  image:
    registry: docker.io
    repository: bitnami/kubectl
    tag: 1.33.4-debian-12-r0
    pullPolicy: "{% if local_cluster is defined %}IfNotPresent{% else %}Never{% endif %}"