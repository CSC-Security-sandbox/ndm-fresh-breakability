#reference: https://artifacthub.io/packages/helm/bitnami/redis?modal=values
global:
  security:
    allowInsecureImages: true

architecture: standalone
auth:
{% if enable_istio | default(false) | bool %}
  # Istio + Wasm filter handles JWT authentication
  enabled: false
  # existingSecret: "redis-credentials"
  # existingSecretPasswordKey: "password"
{% else %}
  # Traditional Redis password authentication (Istio disabled)
  enabled: true
  existingSecret: "redis-credentials"
  existingSecretPasswordKey: "password"
{% endif %}

existingConfigmap: "redis-config"

image:
  registry: docker.io
  repository: "{% if local_cluster is defined %}bitnamilegacy/redis{% else %}bitnami/redis{% endif %}"
  tag: 8.2.1-debian-12-r0
  pullPolicy: "{% if local_cluster is defined %}IfNotPresent{% else %}Never{% endif %}"

master:
  count: 1
{% if enable_istio | default(false) | bool %}
  podAnnotations:
    # Mount Wasm extension into istio-proxy sidecar
    sidecar.istio.io/userVolume: '[{"name":"wasm-extension","configMap":{"name":"redis-jwt-wasm"}}]'
    sidecar.istio.io/userVolumeMount: '[{"name":"wasm-extension","mountPath":"/etc/istio/extensions","readOnly":true}]'
{% endif %}
  service:
    type: NodePort
    ports:
      redis: 6379
    nodePorts:
      redis: "30379"
  persistence:
    enabled: true
    storageClass: "local-storage-redis"
    size: {{ redis_data_volume_size }}
    selector:
        matchLabels:
            role: redis-data
{% if local_cluster is defined %}
  resources:
    requests:
      cpu: "0.3"
      memory: "512Mi"
    limits:
      cpu: "1"
      memory: "1Gi"
{% else %}
  resources:
    requests:
      cpu: "750m"
      memory: "3Gi"
    limits:
      cpu: "1"
      memory: "{{ [3072, (ansible_memtotal_mb * 0.30) | int] | max }}Mi"
{% endif %}
  podSecurityContext:
    enabled: true
    fsGroup: {{ vm_gid }}

  containerSecurityContext:
    enabled: true
    runAsUser: {{ vm_uid }}
    runAsGroup: {{ vm_gid }}
    runAsNonRoot: true
    allowPrivilegeEscalation: false
    seccompProfile:
      type: RuntimeDefault
    capabilities:
      drop: ["ALL"] 

volumePermissions:
  enabled: true
  image:
    registry: docker.io
    repository: "{% if local_cluster is defined %}bitnamilegacy/os-shell{% else %}bitnami/os-shell{% endif %}"
    tag: 12-debian-12-r50
    pullPolicy: "{% if local_cluster is defined %}IfNotPresent{% else %}Never{% endif %}"

replica:
  replicaCount: 0

metrics:
  enabled: true
  containerSecurityContext:
    enabled: true
    runAsUser: {{ vm_uid }}
    runAsGroup: {{ vm_gid }}
    runAsNonRoot: true
    allowPrivilegeEscalation: false
    seccompProfile:
      type: RuntimeDefault
    capabilities:
      drop: ["ALL"]
  image:
    registry: docker.io
    repository: "{% if local_cluster is defined %}bitnamilegacy/redis-exporter{% else %}bitnami/redis-exporter{% endif %}"
    tag: 1.75.0-debian-12-r1
    pullPolicy: "{% if local_cluster is defined %}IfNotPresent{% else %}Never{% endif %}"

kubectl:
  image:
    registry: docker.io
    repository: "{% if local_cluster is defined %}bitnamilegacy/kubectl{% else %}bitnami/kubectl{% endif %}"
    tag: 1.33.4-debian-12-r0
    pullPolicy: "{% if local_cluster is defined %}IfNotPresent{% else %}Never{% endif %}"