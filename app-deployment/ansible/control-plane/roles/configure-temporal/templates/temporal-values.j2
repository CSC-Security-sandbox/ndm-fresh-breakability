server:
  enabled: true
  image:
    repository: temporalio/server
    tag: 1.28.1
    pullPolicy: "{% if local_cluster is defined %}IfNotPresent{% else %}Never{% endif %}"
  replicaCount: 2
  metrics:
    annotations:
      enabled: true
    prometheus:
      timerType: histogram
  config:
    namespaces:
      create: true
      namespace:
        - name: default
          retention: 30d
    persistence:
      default:
        driver: "sql"
        sql:
          driver: "postgres12"
          database: "temporal"
          port: 5432
          host: "postgresql.postgres.svc.cluster.local"
          user: "temporal"
          secretKey: "temporal-db-password"
          secretName: "temporal-credentials"
          maxConns: 450
          maxConnLifetime: "1h"
      visibility:
        driver: "sql"
        sql:
          driver: "postgres12"
          database: "temporal_visibility"
          port: 5432
          host: "postgresql.postgres.svc.cluster.local"
          user: "temporal"
          secretKey: "temporal-db-password"
          secretName: "temporal-credentials"
          maxConns: 450
          maxConnLifetime: "1h"

  dynamicConfig:
    # Max payload size per activity/workflow result
    limit.blobSize:
      - value: 33554432  # 32MB
    limit.historySize:
      - value: 536870912  # 512MB
    limit.historyCount:
      - value: 200000
    history.maximumSignalsPerExecution:
      - value: 100000
    frontend.keepAliveMaxConnectionAge:
      - value: "10m"
    frontend.keepAliveMaxConnectionAgeGrace:
      - value: "1m"

  frontend:
    service:
      type: ClusterIP
      port: 7233
{% if temporal_mtls.enabled | default(false) %}
    # Enable Istio sidecar for frontend (namespace injection enabled)
    podAnnotations:
      sidecar.istio.io/inject: "true"
      traffic.sidecar.istio.io/includeInboundPorts: "7233"
      traffic.sidecar.istio.io/includeOutboundIPRanges: "*"
  history:
    podAnnotations:
      sidecar.istio.io/inject: "true"
  matching:
    podAnnotations:
      sidecar.istio.io/inject: "true"
  worker:
    podAnnotations:
      sidecar.istio.io/inject: "true"
{% endif %}


web:
  enabled: true
  image:
    repository: temporalio/ui
    tag: 2.39.0
    pullPolicy: "{% if local_cluster is defined %}IfNotPresent{% else %}Never{% endif %}"
{% if temporal_mtls.enabled | default(false) %}
  podAnnotations:
    sidecar.istio.io/inject: "true"
{% endif %}
  ingress:
    enabled: true
    annotations:
      kubernetes.io/ingress.class: "public"
      nginx.ingress.kubernetes.io/ssl-redirect: "true"
      nginx.ingress.kubernetes.io/force-ssl-redirect: "true"
    hosts:
      - "/temporal/ui(.*)"
  additionalEnv:
    - name: TEMPORAL_UI_PUBLIC_PATH
      value: "/temporal/ui"

admintools:
  enabled: true
  image:
    repository: temporalio/admin-tools
    tag: 1.28.1-tctl-1.18.4-cli-1.4.1
    pullPolicy: "{% if local_cluster is defined %}IfNotPresent{% else %}Never{% endif %}"
{% if temporal_mtls.enabled | default(false) %}
  podAnnotations:
    sidecar.istio.io/inject: "true"
{% endif %}

schema:
  # Disable sidecar injection for schema Job - Jobs with sidecars never complete
  podAnnotations:
    sidecar.istio.io/inject: "false"

postgresql:
  enabled: false

elasticsearch:
  enabled: false

cassandra:
  enabled: false

mysql:
  enabled: false

prometheus:
  enabled: false

grafana:
  enabled: false