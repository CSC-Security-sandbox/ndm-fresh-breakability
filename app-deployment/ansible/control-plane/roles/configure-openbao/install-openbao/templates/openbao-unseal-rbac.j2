apiVersion: v1
kind: ServiceAccount
metadata:
  name: openbao-unsealer
  namespace: openbao
---

apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: openbao-unseal-role
  namespace: openbao
rules:
- apiGroups: [""]
  resources: ["pods", "pods/exec"]
  verbs: ["get", "list", "watch", "create"]
---

apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: openbao-unseal-rolebinding
  namespace: openbao
subjects:
- kind: ServiceAccount
  name: openbao-unsealer
  namespace: openbao
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: openbao-unseal-role