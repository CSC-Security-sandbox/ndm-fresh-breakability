#reference: https://artifacthub.io/packages/helm/prometheus-community/prometheus?modal=values

configmapReload:
  prometheus:
    enabled: false

serverFiles:
  prometheus.yml:
    scrape_configs: {{ customScrapeConfigs }}
  alerting_rules.yml:
    groups: {{ customAlertingRules }}
    
kube-state-metrics:
  image:
    registry: registry.k8s.io
    repository: kube-state-metrics/kube-state-metrics
    tag: "v2.16.0"
    pullPolicy: "{% if local_cluster is defined %}IfNotPresent{% else %}Never{% endif %}"
  metricLabelsAllowlist:
    - pods=[build-version]

prometheus-node-exporter:
  enabled: true
  image:
    registry: quay.io
    repository: prometheus/node-exporter
    tag: v1.9.1
    pullPolicy: "{% if local_cluster is defined %}IfNotPresent{% else %}Never{% endif %}"

prometheus-pushgateway:
  enabled: true
  image:
    repository: quay.io/prometheus/pushgateway
    tag: v1.11.1
    pullPolicy: "{% if local_cluster is defined %}IfNotPresent{% else %}Never{% endif %}"

server:
  retention: "30d"
  ingress:
    enabled: false
  image:
    repository: quay.io/prometheus/prometheus
    tag: "v3.5.0"
    pullPolicy: "{% if local_cluster is defined %}IfNotPresent{% else %}Never{% endif %}"
  
  securityContext:
    runAsUser: {{ vm_uid }}
    runAsNonRoot: true
    runAsGroup: {{ vm_gid }}
    fsGroup: {{ vm_gid }}
  
  persistentVolume:
    storageClass: "local-storage-prometheus"
    size: {{ prometheus_data_volume_size }}
    selector:
      matchLabels: 
        role: prometheus-server-data
  
alertmanager:
  image:
    repository: quay.io/prometheus/alertmanager
    tag: "v0.28.1"
    pullPolicy: "{% if local_cluster is defined %}IfNotPresent{% else %}Never{% endif %}"

  enabled: true
  podSecurityContext:
    runAsUser: {{ vm_uid }}
    runAsNonRoot: true
    runAsGroup: {{ vm_gid }}
    fsGroup: {{ vm_gid }}
  service:
    type: ClusterIP

  config:
    route:
      receiver: webhook-receiver
      group_by: ['...']
      repeat_interval: 4h
    receivers:
      - name: webhook-receiver
        webhook_configs:
          - url: 'http://admin-service-service.datamigrator.svc.cluster.local:3000/api/v1/email/external'
            send_resolved: true

  persistence:
    enabled: true
    size: {{ prometheus_alertmanager_data_volume_size }}
    storageClass: "local-storage-alertmanager"
    selector:
      matchLabels: 
        role: prometheus-alertmanager-data

  