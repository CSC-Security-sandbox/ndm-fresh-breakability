##reference: https://artifacthub.io/packages/helm/bitnami/postgresql?modal=values

architecture: standalone
global:
  security:
    allowInsecureImages: true
  postgresql:
    auth:
      username: dmadmin
      database: datamigrator  
      existingSecret: postgres-credentials
      secretKeys:
        adminPasswordKey: postgres-password
        userPasswordKey: password

image:
  registry: docker.io
  repository: "{% if local_cluster is defined %}bitnamilegacy/postgresql{% else %}bitnami/postgresql{% endif %}"
  tag: 17.6.0-debian-12-r0
  pullPolicy: "{% if local_cluster is defined %}IfNotPresent{% else %}Never{% endif %}"

primary:
  persistence:
    enabled: true
    storageClass: "local-storage-postgres"
    size: {{ postgres_data_volume_size }}
    selector:
        matchLabels:
            role: postgres-primary-data
  containerSecurityContext:
    runAsUser: {{ vm_uid }}
    runAsNonRoot: true
    runAsGroup: {{ vm_gid }}

  extendedConfiguration: |
{% if local_cluster is defined %}
    # Local cluster: no custom parameters (PostgreSQL built-in defaults)
{% else %}
    # Connections
    max_connections = 500
    tcp_keepalives_idle = 180
    tcp_keepalives_interval = 10
    tcp_keepalives_count = 5

    # Memory (targets ~8 GB peak)
    shared_buffers = 2GB
    effective_cache_size = 4GB
    work_mem = 8MB
    maintenance_work_mem = 512MB
    temp_buffers = 16MB

    # WAL / Checkpoints
    max_wal_size = 4GB
    min_wal_size = 512MB
    checkpoint_timeout = 10min
    checkpoint_completion_target = 0.9
    wal_buffers = 32MB
    wal_compression = zstd

    # SSD tuning
    random_page_cost = 1.1
    effective_io_concurrency = 200
    maintenance_io_concurrency = 200

    # Parallelism
    max_worker_processes = 8
    max_parallel_workers = 4
    max_parallel_workers_per_gather = 2
    max_parallel_maintenance_workers = 2
    parallel_tuple_cost = 0.1
    parallel_setup_cost = 500

    # Autovacuum
    autovacuum_max_workers = 4
    autovacuum_vacuum_cost_limit = 1000
    autovacuum_naptime = 20s
    autovacuum_vacuum_scale_factor = 0.1
    autovacuum_analyze_scale_factor = 0.05

    # Planner
    default_statistics_target = 100
    jit = off

    # Observability
    shared_preload_libraries = 'pg_stat_statements'
{% endif %}

  initdb:
    scriptsConfigMap: postgres-init-config
    user: postgres
    password: {{ postgres_root_password }}

{% if local_cluster is defined %}
  resources:
    requests:
      cpu: "0.5"
      memory: "786Mi"
    limits:
      cpu: "1.2"
      memory: "1.7Gi"
{% else %}
  resources:
    requests:
      cpu: "2"
      memory: "4Gi"
{% endif %}


volumePermissions:
  enabled: true
  image:
    registry: docker.io
    repository: "{% if local_cluster is defined %}bitnamilegacy/os-shell{% else %}bitnami/os-shell{% endif %}"
    tag: 12-debian-12-r50
    pullPolicy: "{% if local_cluster is defined %}IfNotPresent{% else %}Never{% endif %}"

readReplicas:
    replicaCount: 0

metrics:
  enabled: false
  image:
    registry: docker.io
    repository: "{% if local_cluster is defined %}bitnamilegacy/postgres-exporter{% else %}bitnami/postgres-exporter{% endif %}"
    tag: 0.17.1-debian-12-r15
    pullPolicy: "{% if local_cluster is defined %}IfNotPresent{% else %}Never{% endif %}"
