apiVersion: v1
kind: ConfigMap
metadata:
  name: admin-entry-config
  namespace: datamigrator
data:
  admin_entry.sh: |
    #!/bin/bash
    
    set -e
    
{% if local_cluster is defined %}
    apk add --no-cache bash curl nodejs jq
{% endif %}
    cat /vault/secrets/keycloak.env

    KEYCLOAK_USER=$(grep 'KEYCLOAK_ADMIN_USER' /vault/secrets/keycloak.env | cut -d':' -f2 | xargs)
    KEYCLOAK_PASSWORD=$(grep 'KEYCLOAK_ADMIN_PASSWORD' /vault/secrets/keycloak.env | cut -d':' -f2 | xargs)
    CLIENT_SECRET=$(grep 'KEYCLOAK_CLIENT_SECRET' /vault/secrets/keycloak.env | cut -d':' -f2 | xargs)
    KEYCLOAK_BASEURL=http://keycloak.keycloak.svc.cluster.local:80/keycloak
    REALM_NAME=datamigrator
    ADMIN_EMAIL=admin@datamigrator.local
    ADMIN_PASSWORD=Welcome@123
    ADMIN_FIRSTNAME=Admin
    ADMIN_LASTNAME=Admin
    MAPPER_NAME="datamigrate-permissions-mapper"
    MAPPER_USER_ATTRIBUTE="user"
    MAPPER_CLAIM_NAME="user"
    CONTROL_PLANE_IP=${NODE_IP}

    extract_token() {
        local response="$1"
        local token=$(echo "$response" | grep -o '"access_token":"[^"]*' | cut -d'"' -f4)
        echo "$token"
    }

    # First curl command to obtain token
    token_response=$(curl -k --silent --show-error --request POST \
    --url "${KEYCLOAK_BASEURL}/realms/master/protocol/openid-connect/token" \
    --header "Content-Type: application/x-www-form-urlencoded" \
    --data "client_id=admin-cli&grant_type=password&username=${KEYCLOAK_USER}&password=${KEYCLOAK_PASSWORD}")

    # Extract token from response
    token=$(extract_token "$token_response")
    if [ -z "$token" ]; then
        echo "Failed to obtain Keycloak token."
        exit 1
    fi

    REALM_PAYLOAD=$(node -pe "
    JSON.stringify({
        realm: '${REALM_NAME}',
        displayName: '${REALM_NAME}',
        enabled: true,
        accessTokenLifespan: 86400,
        ssoSessionIdleTimeout: 172800,
        ssoSessionMaxLifespan: 172800,
        registrationAllowed: false,
        registrationEmailAsUsername: false,
        verifyEmail: false,
        loginWithEmailAllowed: true,
        duplicateEmailsAllowed: false,
        resetPasswordAllowed: true,
        loginTheme: 'datamigrate',

        // Brute force detection settings
        bruteForceProtected: true,                 // Enables brute force protection
        permanentLockout: false,                   // If true, user must be unlocked by admin; if false, lockout is temporary
        maxFailureWaitSeconds: 900,                // 15 minutes maximum wait time after repeated failures
        minimumQuickLoginWaitSeconds: 60,          // 1 minute minimum wait time after quick login failures
        waitIncrementSeconds: 60,                  // 1 minute increment per failure
        quickLoginCheckMilliSeconds: 1000,         // 1 second window for quick login detection
        maxDeltaTimeSeconds: 43200,                // 12 hours before failure count resets
        failureFactor: 5                           // Number of failures before lockout or delay
    });
    ")

    # Second curl command to create realm
    curl -k --silent --show-error --request POST \
    --url "${KEYCLOAK_BASEURL}/admin/realms" \
    --header "Content-Type: application/json" \
    --header "Authorization: Bearer ${token}" \
    --data "${REALM_PAYLOAD}"

     # Set password policy for the realm
    PASSWORD_POLICY_PAYLOAD=$(node -pe "
    JSON.stringify({
        passwordPolicy: 'length(8) and maxLength(64) and specialChars(1) and upperCase(1) and lowerCase(1) and digits(1) and passwordHistory(3)'
    });
    ")

    curl -k --silent --show-error --request PUT \
    --url "${KEYCLOAK_BASEURL}/admin/realms/${REALM_NAME}" \
    --header "Content-Type: application/json" \
    --header "Authorization: Bearer ${token}" \
    --data-raw "${PASSWORD_POLICY_PAYLOAD}"

    # Third curl command to create client
    CLIENT_PAYLOAD=$(node -pe "
    JSON.stringify({
        clientId: '${REALM_NAME}-client',
        name: '${REALM_NAME}-client',
        description: 'Client for ${REALM_NAME} realm',
        surrogateAuthRequired: false,
        enabled: true,
        redirectUris: ['http://${CONTROL_PLANE_IP}/*', 'https://${CONTROL_PLANE_IP}/*'],
        webOrigins: ['*'],
        clientAuthenticatorType: 'client-secret',
        secret: '${CLIENT_SECRET}',
        protocol: 'openid-connect',
        bearerOnly: false,
        frontchannelLogout: true,
        standardFlowEnabled: true,
        implicitFlowEnabled: false,
        directAccessGrantsEnabled: true,
        serviceAccountsEnabled: false,
        fullScopeAllowed: true,
        publicClient: false,
        frontchannelLogout: true,
        attributes: {
            'oidc.ciba.grant.enabled': false,
            'backchannel.logout.session.required': true,
            'login_theme': 'datamigrate',
            'oauth2.device.authorization.grant.enabled': true,
            'display.on.consent.screen': false,
            'backchannel.logout.revoke.offline.tokens': false
        },
        authenticationFlowBindingOverrides: {},
        fullScopeAllowed: true,
    });
    ")

    # Fourth curl command to create client
    CLIENT_RESPONSE=`curl -k --silent --show-error --request POST \
    --url "${KEYCLOAK_BASEURL}/admin/realms/${REALM_NAME}/clients" \
    --header "Content-Type: application/json" \
    --header "Authorization: Bearer ${token}" \
    --data-raw "$CLIENT_PAYLOAD"`

    echo $CLIENT_RESPONSE

    # Fifth curl command to create initial users
    email=("${ADMIN_EMAIL}")
    first=("${ADMIN_FIRSTNAME}")
    last=("${ADMIN_LASTNAME}")
    pwd=("${ADMIN_PASSWORD}")

    for i in {0..0}
    do
    USER_PAYLOAD=$(node -pe "
        JSON.stringify({
        username: '${email[i]}',
        email: '${email[i]}',
        enabled: true,
        emailVerified: true,
        firstName: '${first[i]}',
        lastName: '${last[i]}',
        credentials: [{
            type: 'password',
            value: '${pwd[i]}',
            temporary: true,
        }],
        requiredActions: [
            'UPDATE_PROFILE',
            'UPDATE_PASSWORD'
        ]
        });
    ")

    curl -k --silent --show-error --request POST \
    --url "${KEYCLOAK_BASEURL}/admin/realms/${REALM_NAME}/users" \
    --header "Content-Type: application/json" \
    --header "Authorization: Bearer ${token}" \
    --data-raw "$USER_PAYLOAD"
    done

    CLIENT_ID=$(curl -k --silent --show-error --request GET \
    --url "${KEYCLOAK_BASEURL}/admin/realms/${REALM_NAME}/clients" \
    --header "Content-Type: application/json" \
    --header "Authorization: Bearer ${token}") 
    CLIENT_ID=$(echo $CLIENT_ID | jq -r ".[] | select(.name == \"${REALM_NAME}-client\") | .id")

    PROTOCOL_MAPPER_PAYLOAD=$(node -pe "
    JSON.stringify({
        name: '${MAPPER_NAME}',
        protocol: 'openid-connect',
        protocolMapper: 'datamigrate-permissions-mapper',
        consentRequired: false,
        config: {
        'claim.name': 'user',
        'access.token.claim': 'true',
        'introspection.token.claim': 'true'
        }
    });
    ")

    curl -k --silent --show-error --request POST \
    --url "${KEYCLOAK_BASEURL}/admin/realms/${REALM_NAME}/clients/${CLIENT_ID}/protocol-mappers/models" \
    --header "Content-Type: application/json" \
    --header "Authorization: Bearer ${token}" \
    --data-raw "$PROTOCOL_MAPPER_PAYLOAD"


    REALM_SETTINGS=$(curl -k --silent --show-error --request GET \
    --url "${KEYCLOAK_BASEURL}/admin/realms/${REALM_NAME}" \
    --header "Content-Type: application/json" \
    --header "Authorization: Bearer ${token}") 
    REALM_SETTINGS_PAYLOAD=$(echo $REALM_SETTINGS | jq -r '.eventsListeners |= . + ["user-profile-event-listener"]')
    echo $REALM_SETTINGS_PAYLOAD | jq

    REALM_SETTINGS_UPDATE=$(curl -k --silent --show-error --request PUT \
    --url "${KEYCLOAK_BASEURL}/admin/realms/${REALM_NAME}" \
    --header "Content-Type: application/json" \
    --header "Authorization: Bearer ${token}" \
    --data "${REALM_SETTINGS_PAYLOAD}")

    # Setup admin client
    ADMIN_CLI_CLIENT_ID=`curl -k --silent --show-error --request GET \
    --url "${KEYCLOAK_BASEURL}/admin/realms/${REALM_NAME}/clients?clientId=admin-cli" \
    --header "Content-Type: application/json" \
    --header "Authorization: Bearer ${token}" | jq '.[0].id'`

    # Remove quotes
    ADMIN_CLI_CLIENT_ID=$(echo $ADMIN_CLI_CLIENT_ID | tr -d '"')

    CLIENT_PAYLOAD=$(node -pe "
    JSON.stringify({
        secret: '${CLIENT_SECRET}',
        publicClient: false,
        standardFlowEnabled: true,
        serviceAccountsEnabled: true,
        attributes: {
        'oidc.ciba.grant.enabled': false,
        'backchannel.logout.session.required': true,
        'login_theme': 'datamigrate',
        'oauth2.device.authorization.grant.enabled': true,
        'display.on.consent.screen': false,
        'backchannel.logout.revoke.offline.tokens': false
        }
    });
    ")

    curl -k --silent --show-error --request PUT \
    --url "${KEYCLOAK_BASEURL}/admin/realms/${REALM_NAME}/clients/${ADMIN_CLI_CLIENT_ID}" \
    --header "Content-Type: application/json" \
    --header "Authorization: Bearer ${token}" \
    --data-raw "$CLIENT_PAYLOAD"

    SERVICE_ACCOUNT_ID=`curl -k --silent --show-error --request GET \
    --url "${KEYCLOAK_BASEURL}/admin/realms/${REALM_NAME}/users?username=service-account-admin-cli" \
    --header "Content-Type: application/json" \
    --header "Authorization: Bearer ${token}" | jq '.[0].id' | tr -d '"'`

    # Retrieve the Role ID
    REALM_MANAGEMENT=`curl -k --silent --show-error --request GET \
    --url "${KEYCLOAK_BASEURL}/admin/realms/${REALM_NAME}/clients?clientId=realm-management" \
    --header "Content-Type: application/json" \
    --header "Authorization: Bearer ${token}" | jq '.[0].id' | tr -d '"'`

    ROLE_ID=`curl -k --silent --show-error --request GET \
    --url "${KEYCLOAK_BASEURL}/admin/realms/${REALM_NAME}/clients/${REALM_MANAGEMENT}/roles?search=manage-users" \
    --header "Content-Type: application/json" \
    --header "Authorization: Bearer ${token}" | jq '.[0].id' | tr -d '"'`

    # Assign the role to the service account
    curl -k --silent --show-error --request POST \
    --url "${KEYCLOAK_BASEURL}/admin/realms/${REALM_NAME}/users/${SERVICE_ACCOUNT_ID}/role-mappings/clients/${REALM_MANAGEMENT}" \
    --header "Content-Type: application/json" \
    --header "Authorization: Bearer ${token}" \
    --data-raw "[{\"id\":\"${ROLE_ID}\",\"name\":\"manage-users\"}]"

    echo "Creating redis-secret-reader role..."
    
    curl -k --silent --show-error --request POST \
    --url "${KEYCLOAK_BASEURL}/admin/realms/${REALM_NAME}/roles" \
    --header "Content-Type: application/json" \
    --header "Authorization: Bearer ${token}" \
    --data-raw '{"name":"redis-secret-reader","description":"Can access Redis credentials via Admin Service API"}'

    # Get all realm roles in one request and parse as needed
    ALL_ROLES=`curl -k --silent --show-error --request GET \
    --url "${KEYCLOAK_BASEURL}/admin/realms/${REALM_NAME}/roles" \
    --header "Content-Type: application/json" \
    --header "Authorization: Bearer ${token}"`

    # Parse default-roles-datamigrator role ID
    DEFAULT_ROLES_ID=$(echo "$ALL_ROLES" | jq -r ".[] | select(.name == \"default-roles-${REALM_NAME}\") | .id")
    echo "Default roles ID: ${DEFAULT_ROLES_ID}"

    # Parse redis-secret-reader role details as complete JSON object
    REDIS_ROLE_DETAILS=$(echo "$ALL_ROLES" | jq -c ".[] | select(.name == \"redis-secret-reader\")")
    echo "Redis role details: ${REDIS_ROLE_DETAILS}"

    # Verify we got both required data
    if [ -z "$DEFAULT_ROLES_ID" ] || [ "$DEFAULT_ROLES_ID" = "null" ]; then
        echo "Error: Could not find default-roles-${REALM_NAME} role"
        exit 1
    fi

    if [ -z "$REDIS_ROLE_DETAILS" ] || [ "$REDIS_ROLE_DETAILS" = "null" ]; then
        echo "Error: Could not find redis-secret-reader role"
        exit 1
    fi

    # Add redis-secret-reader to default-roles-datamigrator composite using roles-by-id endpoint
    curl -k --silent --show-error --request POST \
    --url "${KEYCLOAK_BASEURL}/admin/realms/${REALM_NAME}/roles-by-id/${DEFAULT_ROLES_ID}/composites" \
    --header "Content-Type: application/json" \
    --header "Authorization: Bearer ${token}" \
    --data-raw "[${REDIS_ROLE_DETAILS}]"

    echo "Keycloak setup completed successfully"
    