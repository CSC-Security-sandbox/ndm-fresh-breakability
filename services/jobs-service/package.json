{
  "name": "job-service",
  "version": "0.0.1",
  "description": "Job Mangement Service",
  "author": "Netapp",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:changed": "prettier --write $(git diff --name-only --cached --diff-filter=ACM | grep '\\.ts$')",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:changed": "eslint $(git diff --name-only --cached --diff-filter=ACM) --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage --verbose --reporters=default --reporters=jest-junit --coverage --coverageDirectory=coverage --coverageReporters=lcov",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:report": "jest --coverage --verbose",
    "test:coverage": "jest --coverage --coverageDirectory=coverage --coverageReporters=json-summary --coverageReporters=lcov --coverageReporters=text-summary --outputFile=coverage/unit-test-cases-results.json --json"
  },
  "dependencies": {
    "@nestjs/axios": "4.0.1",
    "@nestjs/common": "11.1.18",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.18",
    "@nestjs/event-emitter": "3.1.0",
    "@nestjs/microservices": "11.1.19",
    "@nestjs/platform-express": "11.1.18",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/swagger": "11.4.2",
    "@nestjs/typeorm": "11.0.1",
    "@netapp-cloud-datamigrate/api-handler-lib": "*",
    "@netapp-cloud-datamigrate/auth-lib": "*",
    "@netapp-cloud-datamigrate/jobs-lib": "*",
    "@netapp-cloud-datamigrate/logger-lib": "*",
    "@temporalio/client": "^1.11.7",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/redis": "^4.0.11",
    "axios": "1.15.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cron-parser": "^4.9.0",
    "dotenv": "^16.4.5",
    "jest-junit": "^16.0.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.2",
    "pg": "^8.12.0",
    "redis": "^4.7.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "11.1.1"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.0.10",
    "@nestjs/testing": "11.1.18",
    "@types/express": "5.0.0",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.7.3"
  },
  "jest-junit": {
    "suiteName": "Unit Tests",
    "outputDirectory": "./test/unit/test-results",
    "outputName": "junit.xml"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "./",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.module.ts",
      "!**/test/**",
      "!**/dist/**",
      "!**/coverage/**",
      "!**.eslintrc.js",
      "!**/main.ts"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/src/$1"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      ".*\\.module\\.ts$",
      "/coverage",
      "/dist",
      "/test/",
      "/config/",
      "/entities/",
      "src/redis/redis.service.ts"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      ".*\\.module\\.ts$",
      "/coverage",
      "/dist",
      "/test/",
      "/config/",
      "/entities/",
      "/dto/",
      "/src/redis/redis.service.ts"
    ]
  }
}
