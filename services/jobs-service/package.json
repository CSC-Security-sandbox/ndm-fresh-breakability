{
  "name": "job-service",
  "version": "0.0.1",
  "description": "Job Mangement Service",
  "author": "Netapp",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:changed": "prettier --write $(git diff --name-only --cached --diff-filter=ACM | grep '\\.ts$')",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "lint:changed": "eslint $(git diff --name-only --cached --diff-filter=ACM | grep '^services/jobs-service/.*\\.ts$' | sed 's|^services/jobs-service/||') --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage --verbose --reporters=default --reporters=jest-junit --coverage --coverageDirectory=coverage --coverageReporters=lcov",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:report": "jest --coverage --verbose",
    "test:coverage": "jest --coverage --coverageDirectory=coverage --coverageReporters=json-summary --coverageReporters=lcov --coverageReporters=text-summary --outputFile=coverage/unit-test-cases-results.json --json"
  },
  "dependencies": {
    "@nestjs/axios": "^3.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/event-emitter": "^2.1.1",
    "@nestjs/microservices": "^10.4.1",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^4.1.1",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/typeorm": "^10.0.2",
    "@netapp-cloud-datamigrate/api-handler-lib": "0.0.5",
    "@netapp-cloud-datamigrate/auth-lib": "0.1.1",
    "@netapp-cloud-datamigrate/jobs-lib": "0.2.53",
    "@netapp-cloud-datamigrate/logger-lib": "0.0.16",
    "@temporalio/client": "^1.11.7",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/redis": "^4.0.11",
    "axios": "^1.7.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cron-parser": "^4.9.0",
    "dotenv": "^16.4.5",
    "fast-glob": "^3.3.3",
    "jest-junit": "^16.0.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.2",
    "pg": "^8.12.0",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3",
    "typescript-eslint": "^8.20.0"
  },
  "overrides": {
    "form-data": "^4.0.4",
    "sha.js": "^2.4.12",
    "validator": "^13.15.22",
    "jws": "^3.2.3",
    "qs": "^6.14.1",
    "js-yaml": "^4.1.1",
    "minimatch": "^10.2.3",
    "serialize-javascript": "^7.0.3",
    "test-exclude": "^8.0.0",
    "typeorm": {
      "glob": "^10.5.0"
    },
    "@nestjs/cli": {
      "glob": "^10.5.0"
    }
  },
  "jest-junit": {
    "suiteName": "Unit Tests",
    "outputDirectory": "./test/unit/test-results",
    "outputName": "junit.xml"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "./",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.module.ts",
      "!**/test/**",
      "!**/dist/**",
      "!**/coverage/**",
      "!**/eslint.config.mjs",
      "!**/main.ts"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/src/$1"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      ".*\\.module\\.ts$",
      "/coverage",
      "/dist",
      "/test/",
      "/config/",
      "/entities/",
      "src/redis/redis.service.ts"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      ".*\\.module\\.ts$",
      "/coverage",
      "/dist",
      "/test/",
      "/config/",
      "/entities/",
      "/dto/",
      "/src/redis/redis.service.ts"
    ]
  }
}
