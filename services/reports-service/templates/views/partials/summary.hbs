<h2
  style="color: #0067C5; font-family: 'Segoe UI', Arial, sans-serif; margin: 20px 0 10px; padding-bottom: 8px; border-bottom: 2px solid #0067C5;">Overview</h2>
<div
  style="overflow-x: auto; margin-bottom: 25px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);"
>
  <table
    style="width: 100%; border-collapse: collapse; font-family: 'Segoe UI', Arial, sans-serif; font-size: 14px; text-align: left;"
  >
   
   <thead>
  <tr style="background-color: #0067C5; color: white;">
    <th colspan="4" style="padding: 10px; border-right: 1px solid rgba(255,255,255,0.3);">
      Source
    </th>
    <th colspan="6" style="padding: 10px; border-right: 1px solid rgba(255,255,255,0.3);">
      Destination
    </th>
    <th colspan="4" style="padding: 10px; border-right: 1px solid rgba(255,255,255,0.3);">
      Process Overview
    </th>
    <th colspan="3" style="padding: 10px;">Validation Metrics</th>
  </tr>
</thead>
<thead>
  <tr style="background-color: #f4f9ff; border-bottom: 2px solid #d0d8e5;">
    <th style="padding: 10px; font-weight: bold;">File Server</th>
    <th style="padding: 10px; font-weight: bold;">Path</th>
    <th style="padding: 10px; font-weight: bold;">Total Files</th>
    <th style="padding: 10px; font-weight: bold;">Space Utilized</th>
    <th style="padding: 10px; font-weight: bold;">File Server</th>
    <th style="padding: 10px; font-weight: bold;">Path</th>
    <th style="padding: 10px; font-weight: bold;">Size</th>
    <th style="padding: 10px; font-weight: bold;">Transfer Protocol</th>
    <th style="padding: 10px; font-weight: bold;">Version</th>
    <th style="padding: 10px; font-weight: bold;">Job Type</th>
    <th style="padding: 10px; font-weight: bold;">ID</th>
    <th style="padding: 10px; font-weight: bold;">Start Time</th>
    <th style="padding: 10px; font-weight: bold;">Elapsed Time</th>
    <th style="padding: 10px; font-weight: bold;">Error Logs</th>
    <th style="padding: 10px; font-weight: bold;">Current Status</th>
    <th style="padding: 10px; font-weight: bold;">File Location</th>
    <th style="padding: 10px; font-weight: bold;">Data Volume</th>
  </tr>
</thead>

    <tbody>
      {{#if summary.length}}
        {{#each summary}}
          <tr style="border-bottom: 1px solid #e1e9f5;">
            <td style="padding: 10px;">{{source.file_server}}</td>
            <td style="padding: 10px;">{{source.path}}</td>
            <td style="padding: 10px;">{{sum
                details.files
                details.directories
              }}</td>
            <td style="padding: 10px;">{{details.capacity}}</td>
            <td style="padding: 10px;">{{target.file_server}}</td>
            <td style="padding: 10px;">{{target.path}}</td>
            <td style="padding: 10px;">{{target.capacity}}</td>
            <td style="padding: 10px;">{{source.protocol}}</td>
            <td style="padding: 10px;">{{source.protocol_version}}</td>
            <td
              style="padding: 10px; font-weight: 500;"
            >{{source.job_type}}</td>
            <td style="padding: 10px;">{{details.job_run_id}}</td>
            <td style="padding: 10px;">{{details.created_at}}</td>
            <td style="padding: 10px;">{{details.duration}} sec</td>
            <td style="padding: 10px;">{{details.errors}}</td>
            <td style="padding: 10px;">{{details.status}}</td>
            <td style="padding: 10px;">{{coc_report.filePath}}</td>
            <td style="padding: 10px;">{{coc_report.size}}</td>
            <td style="padding: 10px;">{{coc_report.status}}</td>
          </tr>
        {{/each}}
      {{else}}
        <tr>
          <td
            colspan="18"
            style="padding: 15px; text-align: center; color: #777;"
          >No data available</td>
        </tr>
      {{/if}}
    </tbody>
  </table>
</div>