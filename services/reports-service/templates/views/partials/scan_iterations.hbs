<h2
  style="color: #0067C5; font-family: 'Segoe UI', Arial, sans-serif; margin: 20px 0 10px; padding-bottom: 8px; border-bottom: 2px solid #0067C5;"
>Iterations</h2>
<div
  style="overflow-x: auto; margin-bottom: 25px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);"
>
  <table
    style="width: 100%; border-collapse: collapse; font-family: 'Segoe UI', Arial, sans-serif; font-size: 14px; text-align: left;"
  >
    <thead>
      <tr style="background-color: #0067C5; color: white;">
        <th
          colspan="4"
          style="padding: 10px; border-right: 1px solid rgba(255,255,255,0.2);"
        >Summary</th>
        <th
          colspan="6"
          style="padding: 10px; border-right: 1px solid rgba(255,255,255,0.2);"
        >Scan Source</th>
        <th colspan="6" style="padding: 10px;">Scan Target</th>
      </tr>
    </thead>
    <thead>
      <tr style="background-color: #f4f9ff; border-bottom: 2px solid #e1e9f5;">
        <th style="padding: 10px; font-weight: 600;">#</th>
        <th style="padding: 10px; font-weight: 600;">Protocol</th>
        <th style="padding: 10px; font-weight: 600;">Status</th>
        <th style="padding: 10px; font-weight: 600; white-space: nowrap;">Start
          Time</th>
        <th
          style="padding: 10px; font-weight: 600; white-space: nowrap;"
        >Duration</th>
        <th style="padding: 10px; font-weight: 600;">Files</th>
        <th style="padding: 10px; font-weight: 600;">Directories</th>
        <th style="padding: 10px; font-weight: 600;">Others</th>
        <th style="padding: 10px; font-weight: 600;">Capacity</th>
        <th style="padding: 10px; font-weight: 600;">Errors</th>
        <th
          style="padding: 10px; font-weight: 600; white-space: nowrap;"
        >Duration</th>
        <th style="padding: 10px; font-weight: 600;">Files</th>
        <th style="padding: 10px; font-weight: 600;">Directories</th>
        <th style="padding: 10px; font-weight: 600;">Others</th>
        <th style="padding: 10px; font-weight: 600;">Capacity</th>
        <th style="padding: 10px; font-weight: 600;">Errors</th>
      </tr>
    </thead>
    <tbody>
      {{#if scan_iterations.length}}
        {{#each scan_iterations}}
          <tr style="border-bottom: 1px solid #e1e9f5;">
            <td style="padding: 10px;">{{job_run_id}}</td>
            <td style="padding: 10px;">{{job_type}}</td>
            <td style="padding: 10px;">{{status}}</td>
            <td style="padding: 10px; white-space: nowrap;">{{start_time}}</td>
            <td style="padding: 10px; white-space: nowrap;">{{s_duration}}</td>
            <td style="padding: 10px;">{{s_files}}</td>
            <td style="padding: 10px;">{{s_directories}}</td>
            <td style="padding: 10px;">{{s_others}}</td>
            <td style="padding: 10px;">{{t_capacity}}</td>
            <td style="padding: 10px;">{{s_errors}}</td>
            <td style="padding: 10px; white-space: nowrap;">{{t_duration}}</td>
            <td style="padding: 10px;">{{t_items}}</td>
            <td style="padding: 10px;">{{t_directories}}</td>
            <td style="padding: 10px;">{{t_others}}</td>
            <td style="padding: 10px;">{{t_capacity}}</td>
            <td style="padding: 10px;">{{t_errors}}</td>
          </tr>
        {{/each}}
      {{else}}
        <tr>
          <td
            colspan="16"
            style="padding: 15px; text-align: center; color: #777;"
          >No data available</td>
        </tr>
      {{/if}}
    </tbody>
  </table>
</div>