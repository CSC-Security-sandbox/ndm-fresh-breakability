<h2
  style="color: #0067C5; font-family: 'Segoe UI', Arial, sans-serif; margin: 20px 0 10px; padding-bottom: 8px; border-bottom: 2px solid #0067C5;"
>Last Iteration</h2>
<div
  style="overflow-x: auto; margin-bottom: 25px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);"
>
  <table
    style="width: 100%; border-collapse: collapse; font-family: 'Segoe UI', Arial, sans-serif; font-size: 14px; text-align: left;"
  >
    <thead>
      <tr style="background-color: #0067C5; color: white;">
        <th
          colspan="2"
          style="padding: 10px; border-right: 1px solid rgba(255,255,255,0.2);"
        >Source</th>
        <th
          colspan="7"
          style="padding: 10px; border-right: 1px solid rgba(255,255,255,0.2);"
        >Destination</th>
        <th
          colspan="2"
          style="padding: 10px; border-right: 1px solid rgba(255,255,255,0.2);"
        >Analysis</th>
        <th
          colspan="4"
          style="padding: 10px; border-right: 1px solid rgba(255,255,255,0.2);"
        >Data Changes</th>
        <th colspan="4" style="padding: 10px;">Performance</th>
      </tr>
    </thead>
    <thead>
      <tr style="background-color: #f4f9ff; border-bottom: 2px solid #e1e9f5;">
        <th style="padding: 10px; font-weight: 600;">File Server</th>
        <th style="padding: 10px; font-weight: 600;">Path</th>
        <th style="padding: 10px; font-weight: 600;">File Server</th>
        <th style="padding: 10px; font-weight: 600;">Path</th>
        <th style="padding: 10px; font-weight: 600;">Protocol</th>
        <th style="padding: 10px; font-weight: 600;">Version</th>
        <th style="padding: 10px; font-weight: 600;">Job Type</th>
        <th style="padding: 10px; font-weight: 600;">ID</th>
        <th style="padding: 10px; font-weight: 600;">Duration</th>
        <th style="padding: 10px; font-weight: 600;">Items</th>
        <th style="padding: 10px; font-weight: 600;">Capacity</th>
        <th style="padding: 10px; font-weight: 600;">Items</th>
        <th style="padding: 10px; font-weight: 600;">Operations</th>
        <th style="padding: 10px; font-weight: 600;">Capacity Copied</th>
        <th style="padding: 10px; font-weight: 600;">Capacity Deleted</th>
        <th style="padding: 10px; font-weight: 600;">Source Scan</th>
        <th style="padding: 10px; font-weight: 600;">Target Scan</th>
        <th style="padding: 10px; font-weight: 600;">Bandwidth</th>
        <th style="padding: 10px; font-weight: 600;">Throughput</th>
      </tr>
    </thead>
    <tbody>
      <tr style="border-bottom: 1px solid #e1e9f5;">
        <td
          style="padding: 10px;"
        >{{last_iteration.summary.source.file_server}}</td>
        <td style="padding: 10px;">{{last_iteration.summary.source.path}}</td>
        <td
          style="padding: 10px;"
        >{{last_iteration.summary.target.file_server}}</td>
        <td style="padding: 10px;">{{last_iteration.summary.target.path}}</td>
        <td
          style="padding: 10px;"
        >{{last_iteration.summary.source.protocol}}</td>
        <td
          style="padding: 10px;"
        >{{last_iteration.summary.source.protocol_version}}</td>
        <td
          style="padding: 10px; font-weight: 500;"
        >{{last_iteration.summary.source.job_type}}</td>
        <td style="padding: 10px;">{{last_iteration.job_run_id}}</td>
        <td style="padding: 10px;">{{last_iteration.duration}}</td>
        <td style="padding: 10px;">{{last_iteration.summary.details.files}}</td>
        <td
          style="padding: 10px;"
        >{{last_iteration.summary.details.capacity}}</td>
        <td style="padding: 10px;">{{last_iteration.summary.details.files}}</td>
        <td style="padding: 10px;">{{last_iteration.delta_operations}}</td>
        <td style="padding: 10px;">{{last_iteration.capacity_copied}}</td>
        <td style="padding: 10px;">{{last_iteration.capacity_deleted}}</td>
        <td style="padding: 10px;">-</td>
        <td style="padding: 10px;">-</td>
        <td style="padding: 10px;">-</td>
        <td style="padding: 10px;">-</td>
      </tr>
    </tbody>
  </table>
</div>