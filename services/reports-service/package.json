{
  "name": "test",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs');const p='node_modules/brace-expansion/index.js';try{let c=fs.readFileSync(p,'utf8');if(!c.includes('module.exports.expand')){fs.appendFileSync(p,'\\nmodule.exports.expand=module.exports;\\n');console.log('patched brace-expansion');}}catch(e){console.warn('brace-expansion patch skipped:',e.message);}\"",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:report": "jest --coverage --verbose",
    "test:coverage": "jest --coverage --coverageDirectory=coverage --coverageReporters=json-summary --coverageReporters=lcov --coverageReporters=text-summary --outputFile=coverage/unit-test-cases-results.json --json"
  },
  "dependencies": {
    "axios": "1.15.2",
    "@nestjs/common": "11.1.18",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.18",
    "@nestjs/microservices": "11.1.19",
    "@nestjs/platform-express": "11.1.18",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/swagger": "11.4.2",
    "@nestjs/typeorm": "11.0.1",
