    "typeorm": "^0.3.25"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.0.10",
    "@nestjs/testing": "11.1.18",
    "@types/escape-html": "^1.0.4",
    "@types/express": "5.0.0",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/sanitize-html": "^2.16.0",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "8.25.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "./",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.module.ts",
      "!**/test/**",
      "!**/dist/**",
      "!**/coverage/**",
      "!**.eslintrc.js",
      "!**/main.ts",
      "!**/*.types.ts",
      "!src/temporal/**",
      "!src/interceptors/**",
      "!src/decorators/**",
      "!src/common/interceptors/**",
      "!src/common/decorators/**",
      "!src/constants/custom-response-message.ts"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/src/$1"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      ".*\\.module\\.ts$",
      "/coverage",
      "/dist",
      "/test/",
      "/config/",
      "/entities/"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      ".*\\.module\\.ts$",
      "/coverage",
      "/dist",
      "/test/",
      "/config/",
      "/entities/",
      "/dto/",
      ".*types\\.ts$",
      "/src/interceptors/",
      "/src/decorators/",
      "/src/common/interceptors/",
      "/src/common/decorators/"
    ]
  },
  "overrides": {
    "fast-uri": "3.1.2",
    "follow-redirects": "1.16.0",
    "flatted": "3.4.2",
    "picomatch": "4.0.4",
    "postcss": "8.5.10",
    "multer": "2.1.1",
    "lodash": "4.18.1",
    "brace-expansion": "^2.0.1",
    "form-data": "^4.0.4",
    "sha.js": "^2.4.12",
    "@swc/core": "1.13.5",
    "validator": "13.15.22",
    "qs": "6.14.1",
    "js-yaml": "4.1.1",
    "test-exclude": "^8.0.0",
    "minimatch": "^10.2.3",
    "serialize-javascript": "^7.0.3",
    "hbs": {
      "handlebars": "^4.7.9"
    },
    "basic-ftp": "5.3.1",
    "protobufjs": "7.5.5",
    "path-to-regexp": "8.4.2",
    "@nestjs/common": "11.1.18",
    "@nestjs/core": "11.1.18"
  }
