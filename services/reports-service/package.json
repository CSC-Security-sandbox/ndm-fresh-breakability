{
  "name": "test",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:report": "jest --coverage --verbose",
    "test:coverage": "jest --coverage --coverageDirectory=coverage --coverageReporters=json-summary --coverageReporters=lcov --coverageReporters=text-summary --outputFile=coverage/unit-test-cases-results.json --json"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.16",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/microservices": "^10.4.15",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^10.0.2",
    "@netapp-cloud-datamigrate/api-handler-lib": "0.0.5",
    "@netapp-cloud-datamigrate/auth-lib": "0.0.5",
    "@netapp-cloud-datamigrate/jobs-lib": "0.2.54",
    "@netapp-cloud-datamigrate/logger-lib": "0.0.16",
    "@temporalio/worker": "^1.12.1",
    "@temporalio/workflow": "^1.12.1",
    "@types/puppeteer": "^7.0.4",
    "amqp-connection-manager": "^4.1.14",
    "amqplib": "^0.10.5",
    "archiver": "^7.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "fast-csv": "^5.0.2",
    "glob": "^11.1.0",
    "hbs": "^4.2.0",
    "multer": "^2.0.2",
    "pdf-lib": "^1.17.1",
    "pg": "^8.13.0",
    "puppeteer": "^23.11.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "sanitize-html": "^2.17.0",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/escape-html": "^1.0.4",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/sanitize-html": "^2.16.0",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "8.25.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "./",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.module.ts",
      "!**/test/**",
      "!**/dist/**",
      "!**/coverage/**",
      "!**.eslintrc.js",
      "!**/main.ts",
      "!**/*.types.ts",
      "!src/temporal/**",
      "!src/interceptors/**",
      "!src/decorators/**",
      "!src/common/interceptors/**",
      "!src/common/decorators/**",
      "!src/constants/custom-response-message.ts"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/src/$1"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      ".*\\.module\\.ts$",
      "/coverage",
      "/dist",
      "/test/",
      "/config/",
      "/entities/"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      ".*\\.module\\.ts$",
      "/coverage",
      "/dist",
      "/test/",
      "/config/",
      "/entities/",
      "/dto/",
      ".*types\\.ts$",
      "/src/interceptors/",
      "/src/decorators/",
      "/src/common/interceptors/",
      "/src/common/decorators/"
    ]
  },
  "overrides": {
    "multer": "^2.0.2",
    "brace-expansion": "1.1.12",
    "form-data": "^4.0.4",
    "sha.js": "^2.4.12",
    "@swc/core": "1.13.5",
    "validator": "13.15.22",
    "qs": "6.14.1",
    "js-yaml": "4.1.1",
    "test-exclude": "^6.0.0"
  }
}
