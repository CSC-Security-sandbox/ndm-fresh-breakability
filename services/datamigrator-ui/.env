VITE_PORT={PORT_TO_EXPOSE}
VITE_SESSION_KEY={SESSION_KEY}
VITE_API_LIMIT=1000
VITE_TIME_INTERVAL=30000 #in milliseconds

# Following URLs will be used for mapping API URL - FROM
VITE_ADMIN_SERVICE_URL={URL}
VITE_CONFIG_SERVICE_URL={URL}
VITE_JOBS_SERVICE_URL={URL}
VITE_WORKERS_SERVICE_URL={URL}
VITE_REPORTS_SERVICE_URL={URL}

# Following URLs will be used for mapping API URL - TO (nginx/docker)
VITE_ADMIN_SERVICE_ENDPOINT={URL}
VITE_CONFIG_SERVICE_ENDPOINT={URL}
VITE_JOBS_SERVICE_ENDPOINT={URL}
VITE_WORKERS_SERVICE_ENDPOINT={URL}
VITE_REPORTS_SERVICE_ENDPOINT={URL}

# KEYCLOAK
VITE_KEYCLOAK_HOST={KEYCLOAK_URL}
VITE_KEYCLOAK_REALM=datamigrator
VITE_KEYCLOAK_CLIENT=datamigrator-client
VITE_KEYCLOAK_AUTHORITY={KEYCLOAK_URL}/realms/datamigrator
VITE_KEYCLOAK_GRANT_TYPE=authorization_code
VITE_KEYCLOAK_CLIENT_ID=datamigrator-client
VITE_KEYCLOAK_CLIENT_SECRET={SECRET}
VITE_KEYCLOAK_REDIRECT_URI={HOMEPAGE_URL}
VITE_KEYCLOAK_RESPONSE_TYPE=code
VITE_KEYCLOAK_POST_LOGOUT_REDIRECT_URI={HOMEPAGE_URL}
VITE_GRAFANA_URL={GRAFANA_URL}

# Following are the text messages which will be used across the application UI.
VITE_REFRESH_TO_GET_LATEST_DATA=Refresh the screen to load updated data.