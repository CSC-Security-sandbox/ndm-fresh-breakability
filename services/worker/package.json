{
  "name": "worker",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "bin": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start-w1": "nest start --env-file .worker1",
    "start-w2": "nest start --env-file .worker2",
    "start:dev": "nest start --watch  --trace-warnings",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:profile": "clinic flame -- node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "pkg": "pkg .",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:report": "jest --coverage --verbose",
    "test:coverage": "jest --coverage --coverageDirectory=coverage --coverageReporters=json-summary --coverageReporters=lcov --coverageReporters=text-summary --outputFile=coverage/unit-test-cases-results.json --json"
  },
  "pkg": {
    "assets": [
      "node_modules/axios/**",
      "node_modules/sqlite3/**/*",
      "dist/**",
      "logs/**",
      "node_modules/tslib/**",
      "node_modules/@netapp-cloud-datamigrate/**",
      "node_modules/@temporalio/**",
      "node_modules/tar/**",
      "node_modules/adm-zip/**"
    ],
    "targets": [
      "node18-linux-x64",
      "node18-macos-arm64",
      "node18-win-x64",
      "node18-linux-arm64"
    ],
    "scripts": "build/**/*.js",
    "outputPath": "pkg",
    "logLevel": "info"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.0",
    "@nestjs/common": "^10.4.16",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^4.1.2",
    "@netapp-cloud-datamigrate/jobs-lib": "0.2.67",
    "@netapp-cloud-datamigrate/logger-lib": "0.0.16",
    "@temporalio/client": "^1.11.6",
    "@temporalio/workflow": "^1.11.6",
    "axios": "1.15.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "koffi": "^2.14.1",
    "node-os-utils": "^1.3.7",
    "ping": "^0.4.4",
    "prom-client": "^15.1.3",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "systeminformation": "5.31.6",
    "tar": "^7.5.8",
    "adm-zip": "^0.5.16"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@temporalio/testing": "^1.11.7",
    "@temporalio/worker": "^1.11.7",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "8.25.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.7.3",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1"
  },
  "overrides": {
    "fast-uri": "3.1.2",
    "follow-redirects": "1.16.0",
    "flatted": "3.4.2",
    "picomatch": "4.0.4",
    "postcss": "8.5.10",
    "multer": "2.1.1",
    "lodash": "4.18.1",
    "form-data": "^4.0.4",
    "sha.js": "^2.4.12",
    "qs": "^6.14.1",
    "@isaacs/brace-expansion": "5.0.1",
    "diff": "4.0.4",
    "serialize-javascript": "^7.0.3",
    "minimatch": "^10.2.3",
    "test-exclude": "^8.0.0",
    "handlebars": "^4.7.9",
    "protobufjs": "7.5.6",
    "brace-expansion": "5.0.6",
    "@swc/core": "1.15.21"
  },
  "jest-junit": {
    "suiteName": "Unit Tests",
    "outputDirectory": "./test/unit/test-results",
    "outputName": "junit.xml"
  },
  "jest": {
    "workerThreads": true,
    "coverageProvider": "babel",
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "./",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.spec.ts",
      "!**/*.module.ts",
      "!**/test/**",
      "!**/dist/**",
      "!**/coverage/**",
      "!**.eslintrc.js",
      "!**/main.ts",
      "!src/workflows/**"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/src/$1"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      ".*\\.module\\.ts$",
      "/coverage",
      "/dist/",
      "src/activities/common/win-shell.service.spec.ts",
      "/dist",
      "/test/",
      "src/workflows/speed-test/speed-test-job-workflow.spec.ts"
    ],
    "globals": {
      "ts-jest": {
        "isolatedModules": true
      }
    },
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/jest.teardown.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      ".*\\.module\\.ts$",
      "/coverage",
      "/dist",
      "/test/",
      "src/logger/logger.service.ts",
      "src/activities/common/win-shell.service.ts",
      "src/activities/core/migrate/sync-activity.service.ts",
      "src/activities/core/scan/discovery/discovery-scan.service.ts",
      "src/activities/core/utils/file-type-detection.service.ts",
      "src/activities/speed-test/speed-test-activities.ts",
      "src/activities/upgrade/binary-handler.interface.ts",
      "src/activities/upgrade/upgrade.activity.service.ts",
      "src/activities/core/migrate/ctime-test-triggers.service.ts",
      "src/activities/upgrade/handlers/linux-binary.handler.ts",
      "src/activities/upgrade/handlers/windows-binary.handler.ts",
      "src/activities/utils/utils.ts",
      "src/activities/validate-path/validate-path.service.ts",
      "src/activities/working-directory/working-directory.service.ts",
      "src/metrics/metrics.service.ts",
      "src/protocols/nfs/nfs.protocol.ts",
      "src/protocols/smb/smb.protocol.ts",
      "src/storage-clients/storage-client.ts",
      "src/storage-clients/isilon/isilon-storage-client.ts",
      "src/utils/temporal.utils.ts",
      "src/utils/worker-manager.mappers.ts",
      "src/work-manager/factory/worker-options.factory.service.ts",
      "src/work-manager/work-manager.service.ts"
    ]
  }
}
