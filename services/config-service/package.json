{
  "name": "config-service",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage --verbose --reporters=default --reporters=jest-junit --coverage --coverageDirectory=coverage --coverageReporters=lcov",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:report": "jest --coverage --verbose",
    "test:coverage": "jest --coverage --coverageDirectory=coverage --coverageReporters=json-summary --coverageReporters=lcov --coverageReporters=text-summary --outputFile=coverage/unit-test-cases-results.json --json"
  },
  "dependencies": {
    "@nestjs/axios": "4.0.1",
    "@nestjs/common": "11.1.18",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.18",
    "@nestjs/microservices": "11.1.19",
    "@nestjs/mongoose": "11.0.4",
    "@nestjs/platform-express": "11.1.18",
    "@nestjs/platform-socket.io": "11.1.18",
    "@nestjs/swagger": "11.4.2",
    "@nestjs/typeorm": "11.0.1",
    "@nestjs/websockets": "11.1.18",
    "@netapp-cloud-datamigrate/api-handler-lib": "0.0.10",
    "@netapp-cloud-datamigrate/auth-lib": "0.1.4",
    "@netapp-cloud-datamigrate/logger-lib": "0.0.18",
    "@temporalio/client": "^1.11.6",
    "@temporalio/worker": "^1.11.6",
    "@temporalio/workflow": "^1.11.6",
    "@types/jsonwebtoken": "^9.0.6",
    "amqp-connection-manager": "^4.1.14",
    "amqplib": "^0.10.4",
    "axios": "1.17.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "jest-junit": "^16.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.3",
    "mysql2": "^3.11.2",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "sanitize-html": "^2.17.3",
    "socket.io": "^4.7.5",
    "typeorm": "^0.3.20",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.0.10",
    "@nestjs/testing": "11.1.27",
    "@types/escape-html": "^1.0.4",
    "@types/express": "5.0.0",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/sanitize-html": "^2.16.0",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "overrides": {
    "fast-uri": "3.1.2",
    "follow-redirects": "1.16.0",
    "flatted": "3.4.2",
    "picomatch": "4.0.4",
    "postcss": "8.5.10",
    "multer": "2.1.1",
    "lodash": "4.18.1",
    "form-data": "^4.0.4",
    "sha.js": "^2.4.12",
    "serialize-javascript": "^7.0.3",
    "handlebars": "^4.7.9",
    "protobufjs": "7.5.6",
    "path-to-regexp": "8.4.2",
    "brace-expansion": "5.0.6",
    "uuid": "14.0.0"
  },
  "jest-junit": {
    "suiteName": "Unit Tests",
    "outputDirectory": "./test/unit/test-results",
    "outputName": "junit.xml"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "./",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.module.ts",
      "!**/test/**",
      "!**/dist/**",
      "!**/coverage/**",
      "!**.eslintrc.js",
      "!**/main.ts"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/src/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!uuid)"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      ".*\\.module\\.ts$",
      "/coverage",
      "/dist",
      "/test/",
      "src/middleware",
      "src/utils",
      "/config/"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      ".*\\.module\\.ts$",
      "/coverage",
      "/dist",
      "/test/",
      "/entities/",
      "src/middleware",
      "/dto/",
      "/config/",
      "src/utils"
    ]
  }
}
