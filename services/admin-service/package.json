{
  "name": "admin-service",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "ENABLE_FILE_LOGGING=true ENABLE_CONSOLE_LOGGING=false nest start",
    "start:dev": "LOG_LEVEL=debug ENABLE_FILE_LOGGING=false ENABLE_CONSOLE_LOGGING=true nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "NODE_ENV=test LOG_LEVEL=info ENABLE_FILE_LOGGING=false ENABLE_CONSOLE_LOGGING=false jest",
    "test:watch": "NODE_ENV=test LOG_LEVEL=info ENABLE_FILE_LOGGING=false ENABLE_CONSOLE_LOGGING=false jest --watch",
    "test:cov": "NODE_ENV=test LOG_LEVEL=error ENABLE_FILE_LOGGING=false ENABLE_CONSOLE_LOGGING=false jest --coverage",
    "test:debug": "NODE_ENV=test LOG_LEVEL=debug ENABLE_FILE_LOGGING=false ENABLE_CONSOLE_LOGGING=false node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:report": "jest --coverage --verbose",
    "test:coverage": "jest --coverage --coverageDirectory=coverage --coverageReporters=json-summary --coverageReporters=lcov --coverageReporters=text-summary --outputFile=coverage/unit-test-cases-results.json --json",
    "prepare": "husky"
  },
  "dependencies": {
    "@nestjs/common": "11.1.18",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.18",
    "@nestjs/platform-express": "11.1.18",
    "@nestjs/swagger": "11.4.2",
    "@nestjs/typeorm": "11.0.1",
    "@netapp-cloud-datamigrate/api-handler-lib": "0.0.10",
    "@netapp-cloud-datamigrate/auth-lib": "0.1.4",
    "@netapp-cloud-datamigrate/logger-lib": "0.0.18",
    "@temporalio/client": "^1.11.7",
    "axios": "1.17.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "nodemailer": "^8.0.5",
    "nodemailer-express-handlebars": "^7.0.0",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "sqlite3": "^6.0.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^1.0.0",
    "uuid": "11.1.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.24.0",
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.0.10",
    "@nestjs/testing": "11.1.18",
    "@types/express": "5.0.0",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/nodemailer": "^6.4.17",
    "@types/nodemailer-express-handlebars": "^4.0.5",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.61.1",
    "better-sqlite3": "^12.10.1",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1"
  },
  "overrides": {
    "fast-uri": "3.1.2",
    "follow-redirects": "1.16.0",
    "flatted": "3.4.2",
    "picomatch": "4.0.4",
    "postcss": "8.5.10",
    "multer": "2.1.1",
    "lodash": "4.18.1",
    "form-data": "^4.0.4",
    "sha.js": "^2.4.12",
    "tar": "^7.5.11",
    "fast-xml-parser": "^5.5.7",
    "glob": "^10.5.0",
    "jws": "^3.2.3",
    "qs": "^6.14.1",
    "serialize-javascript": "^7.0.3",
    "validator": "13.15.22",
    "test-exclude": "^8.0.0",
    "handlebars": "^4.7.9",
    "protobufjs": "7.5.6",
    "path-to-regexp": "8.4.2",
    "brace-expansion": "5.0.6",
    "uuid": "11.1.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "./",
    "setupFilesAfterEnv": [
      "<rootDir>/src/test-setup.ts"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.module.ts",
      "!**/test/**",
      "!**/dist/**",
      "!**/coverage/**",
      "!**.eslintrc.js",
      "!**/main.ts",
      "!src/test-utils/**"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/src/$1"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      ".*\\.module\\.ts$",
      "/coverage",
      "/dist",
      "/test/"
    ]
  }
}
