<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DataMigrator Alert</title>
</head>

<body style="font-family: Arial, sans-serif; background-color: #f9f9f9; padding: 20px;">
    <div style="max-width: 600px; background: #fff; padding: 20px; border-radius: 5px; border: 1px solid #ddd;">
        {{#if isResolved}}
        <h2 style="color: #28a745;">✅ DataMigrator Alert Resolved - Severity: {{severity}}</h2>
        {{else}}
        <h2 style="color: #d9534f;">🚨 DataMigrator Alert - Severity: {{severity}}</h2>
        {{/if}}
        {{#if podName}}
        <p><strong>Pod:</strong> {{podName}}</p>
        {{/if}}
        {{#if instanceName}}
        <p><strong>Node:</strong> {{instanceName}}</p>
        {{/if}}
        <p><strong>Description:</strong> {{description}}</p>
        <p><strong>Summary:</strong> {{summary}}</p>
        <hr>
        <footer style="font-size: 12px; color: #555;">
            This is an automated alert from DataMigrator. Please do not reply to this email.
        </footer>
    </div>
</body>

</html>