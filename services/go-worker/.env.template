# Go worker environment template
# Mirrors the env-driven setup used by services/worker, but tailored for go-worker.
# Copy to .env and fill in values.

# ----------------------------- NFS (Linux) -----------------------------
NFS_LINUX_LIST_PATH_CMD='showmount -e ${HOST}'
NFS_LINUX_MOUNT_PATH_CMD='mount -t nfs -o nfsvers=${PROTOCOL_VERSION} ${HOST}:${MOUNT_PATH} ${DIR_PATH}'
NFS_LINUX_UNMOUNT_PATH_CMD='umount ${DIR_PATH}'
NFS_LINUX_CHECK_MOUNT_PATH_CMD='mount | grep ${PATH}'
# Optional (only if you use PatternVersionDetail)
NFS_LINUX_VERSION_DETAIL_CMD='nfsstat -m'

# ----------------------------- SMB (Linux) -----------------------------
SMB_LINUX_LIST_PATH_CMD='smbclient -L ${HOST} -U ${USERNAME}%${PASSWORD}'
SMB_LINUX_MOUNT_PATH_CMD='mount -t cifs //${HOST}${MOUNT_PATH} ${DIR_PATH} -o username=${USERNAME},password=${PASSWORD},vers=3.0'
SMB_LINUX_UNMOUNT_PATH_CMD='umount ${DIR_PATH}'
# Optional (only if you use PatternVersionDetail / PatternSaveCreds)
SMB_LINUX_VERSION_DETAIL_CMD='smbclient --version'
LINUX_SAVE_CREDS_CMD='true'

# ----------------------------- Disk / OS helpers -----------------------------
LINUX_FSTAB_PATH='/etc/fstab'
LINUX_AVAILABLE_DISK_SPACE_CMD="df -Pk \"${DIR_PATH}\" | awk 'NR==2 { print $4 * 1024 }'"
LINUX_USED_DISK_SPACE="df -B1 \"${MOUNT_PATH}\" | tail -1"

# ----------------------------- Worker core -----------------------------
WORKER_ID=
WORKER_SECRET=
PROJECT_ID=
BUILD_ID=1.0.0
BASE_WORKING_PATH=/mnt/datamigrator
LOG_LEVEL=info

# URLs / endpoints
WORKER_CONFIG_URL=http://localhost:3002
WORKER_JOB_SERVICE_URL=http://localhost:3006
WORKER_REPORT_SERVICE_URL=http://localhost:3003
TEMPORAL_ADDRESS=localhost:7233

# Keycloak
KEYCLOAK_BASE_URL=http://localhost:7080
KEYCLOAK_REALM=datamigrator

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=
REDIS_MEM_USAGE_THRESHOLD=90
REDIS_STREAM_GROUP_SIZE=2000

# Concurrency / performance
THREAD_BANDS=1kb,1500;1mb,1000;10mb,100;100mb,10;1gb,1
THREAD_COUNT=5
MAX_BUFFER_SIZE=1048576
MAX_OPERATION_RETRY=3
MAX_MIGRATION_COMMAND=100
MAX_SCAN_COMMAND=500
MAX_COMMAND_CONCURRENCY=100
MAX_WRITE_CONCURRENCY=100
COMMANDS_IN_TASK=100
MAX_CMDS_IN_STREAM=5000
META_UPDATED_TOLERANCE_MS=30000
MIGRATION_TASK_LIMIT=100
OPERATION_TIMEOUT=5000
JOB_TASK_ACTIVITY_CONCURRENCY=1
WORKER_SHUTDOWN_FORCE_TIME=10s

# Health / telemetry
HEALTH_CHECK_INTERVAL=5
CHECK_AVAILABLE_DISK_SPACE=false
OTEL_COLLECTOR_ENDPOINT=localhost:4318
VERSIONS_PATH_LINUX=/opt/datamigrator/conf/versions.conf

# Speed test
SPEED_TEST_FILE_NAME=1GB_zero_file.bin
SPEED_TEST_FILE_SIZE_GB=1
SPEED_TEST_TIMEOUT=120000

# Temporal TLS / JWT (optional)
TEMPORAL_TLS_ENABLED=false
TEMPORAL_TLS_CA_CERT=
TEMPORAL_TLS_SERVER_NAME=
TEMPORAL_JWT_ENABLED=false

# Metrics
METRICS_ENABLED=false
METRICS_COLLECTION_INTERVAL=5000
METRICS_PUSH_INTERVAL=15000
WORKER_METRICS_COLLECTION_INTERVAL=2000

# Optional
CONTROL_PLANE_IP=
